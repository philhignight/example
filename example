package com.example.todoapp.service;

import java.io.*;
import java.nio.file.*;
import java.util.Optional;
import java.util.Properties;

import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import com.example.todoapp.processor.ProcessingState;
import com.example.todoapp.provider.FileSystemProvider;

/**
 * Service for managing bookmark files that track processing state.
 * Enables recovery from interruptions by storing progress information.
 */
public class BookmarkService {
    
    private static final Logger LOGGER = LogManager.getLogger(BookmarkService.class);
    private static final String BOOKMARK_FILE = "bookmark.txt";
    
    private final String bookmarkDir;
    private final FileSystemProvider fileSystemProvider;
    
    public BookmarkService(String bookmarkDir, FileSystemProvider fileSystemProvider) {
        this.bookmarkDir = bookmarkDir;
        this.fileSystemProvider = fileSystemProvider;
    }
    
    /**
     * State object representing bookmark information.
     */
    public static class BookmarkState {
        private final String todoFile;
        private final long batchId;
        private final String inputFile;
        private final int lastCompletedLine;
        private final int totalLines;
        private final String processType;
        private final String status;
        
        public BookmarkState(String todoFile, long batchId, String inputFile, 
                           int lastCompletedLine, int totalLines, String processType, String status) {
            this.todoFile = todoFile;
            this.batchId = batchId;
            this.inputFile = inputFile;
            this.lastCompletedLine = lastCompletedLine;
            this.totalLines = totalLines;
            this.processType = processType;
            this.status = status;
        }
        
        // Getters
        public String getTodoFile() { return todoFile; }
        public long getBatchId() { return batchId; }
        public String getInputFile() { return inputFile; }
        public int getLastCompletedLine() { return lastCompletedLine; }
        public int getTotalLines() { return totalLines; }
        public String getProcessType() { return processType; }
        public String getStatus() { return status; }
    }
    
    /**
     * Create a new bookmark for starting processing.
     */
    public void createBookmark(String todoFile, long batchId, String inputFile, 
                             int totalLines, String processType) throws IOException {
        LOGGER.debug("Creating bookmark - submission: {}, batch: {}, file: {}, lines: {}, type: {}",
            todoFile, batchId, inputFile, totalLines, processType);
            
        Properties props = new Properties();
        props.setProperty("submission_id", todoFile);
        props.setProperty("batch_id", String.valueOf(batchId));
        props.setProperty("input_file", inputFile);
        props.setProperty("last_completed_line", "0");
        props.setProperty("total_lines", String.valueOf(totalLines));
        props.setProperty("process_type", processType);
        props.setProperty("status", ProcessingState.TODO_FILE_GENERATED.name());
        
        saveBookmark(props);
        LOGGER.info("Created bookmark for submission {} with {} total lines", todoFile, totalLines);
    }
    
    /**
     * Update the progress (last completed line number).
     */
    public void updateProgress(int lastCompletedLine) throws IOException {
        Optional<BookmarkState> currentState = loadBookmark();
        if (!currentState.isPresent()) {
            LOGGER.error("Cannot update progress - no bookmark exists");
            throw new IllegalStateException("Cannot update progress - no bookmark exists");
        }
        
        Properties props = new Properties();
        BookmarkState state = currentState.get();
        props.setProperty("submission_id", state.getTodoFile());
        props.setProperty("batch_id", String.valueOf(state.getBatchId()));
        props.setProperty("input_file", state.getInputFile());
        props.setProperty("last_completed_line", String.valueOf(lastCompletedLine));
        props.setProperty("total_lines", String.valueOf(state.getTotalLines()));
        props.setProperty("process_type", state.getProcessType());
        props.setProperty("status", state.getStatus());
        
        saveBookmark(props);
        
        // Log at different levels based on progress
        int percentComplete = (lastCompletedLine * 100) / state.getTotalLines();
        if (lastCompletedLine % 100 == 0) {
            LOGGER.info("Processing progress: {}/{} ({}%)", lastCompletedLine, state.getTotalLines(), percentComplete);
        } else {
            LOGGER.debug("Updated bookmark progress to line {}", lastCompletedLine);
        }
    }
    
    /**
     * Update the status of processing.
     */
    public void updateStatus(ProcessingState status) throws IOException {
        LOGGER.debug("Updating bookmark status to: {}", status);
        
        Optional<BookmarkState> currentState = loadBookmark();
        if (!currentState.isPresent()) {
            LOGGER.error("Cannot update status - no bookmark exists");
            throw new IllegalStateException("Cannot update status - no bookmark exists");
        }
        
        Properties props = new Properties();
        BookmarkState state = currentState.get();
        props.setProperty("submission_id", state.getTodoFile());
        props.setProperty("batch_id", String.valueOf(state.getBatchId()));
        props.setProperty("input_file", state.getInputFile());
        props.setProperty("last_completed_line", String.valueOf(state.getLastCompletedLine()));
        props.setProperty("total_lines", String.valueOf(state.getTotalLines()));
        props.setProperty("process_type", state.getProcessType());
        props.setProperty("status", status.name());
        
        saveBookmark(props);
        LOGGER.info("Updated bookmark status from {} to {}", state.getStatus(), status);
    }
    
    /**
     * Load existing bookmark if it exists.
     */
    public Optional<BookmarkState> loadBookmark() {
        File bookmarkFile = new File(bookmarkDir, BOOKMARK_FILE);
        if (!bookmarkFile.exists()) {
            LOGGER.debug("No bookmark file found at: {}", bookmarkFile.getAbsolutePath());
            return Optional.empty();
        }
        
        LOGGER.debug("Loading bookmark from: {}", bookmarkFile.getAbsolutePath());
        
        try (InputStream is = new FileInputStream(bookmarkFile)) {
            Properties props = new Properties();
            props.load(is);
            
            BookmarkState state = new BookmarkState(
                props.getProperty("submission_id"),
                Long.parseLong(props.getProperty("batch_id", "0")),
                props.getProperty("input_file"),
                Integer.parseInt(props.getProperty("last_completed_line", "0")),
                Integer.parseInt(props.getProperty("total_lines", "0")),
                props.getProperty("process_type", ""),
                props.getProperty("status", "UNKNOWN")
            );
            
            LOGGER.info("Loaded bookmark for submission {} - status: {}, progress: {}/{} ({}%)", 
                state.getTodoFile(), state.getStatus(), state.getLastCompletedLine(), 
                state.getTotalLines(), (state.getLastCompletedLine() * 100) / Math.max(1, state.getTotalLines()));
            return Optional.of(state);
            
        } catch (Exception e) {
            LOGGER.error("Failed to load bookmark file: {}", bookmarkFile.getAbsolutePath(), e);
            return Optional.empty();
        }
    }
    
    /**
     * Delete the bookmark file.
     */
    public void deleteBookmark() throws IOException {
        File bookmarkFile = new File(bookmarkDir, BOOKMARK_FILE);
        if (bookmarkFile.exists()) {
            LOGGER.debug("Deleting bookmark file: {}", bookmarkFile.getAbsolutePath());
            if (!bookmarkFile.delete()) {
                LOGGER.error("Failed to delete bookmark file: {}", bookmarkFile.getAbsolutePath());
                throw new IOException("Failed to delete bookmark file: " + bookmarkFile.getAbsolutePath());
            }
            LOGGER.info("Successfully deleted bookmark file");
        } else {
            LOGGER.debug("No bookmark file to delete");
        }
    }
    
    /**
     * Check if a bookmark exists.
     */
    public boolean bookmarkExists() {
        return new File(bookmarkDir, BOOKMARK_FILE).exists();
    }
    
    private void saveBookmark(Properties props) throws IOException {
        // Ensure bookmark directory exists
        File bookmarkDirFile = new File(bookmarkDir);
        if (!bookmarkDirFile.exists()) {
            LOGGER.debug("Creating bookmark directory: {}", bookmarkDir);
            if (!bookmarkDirFile.mkdirs()) {
                LOGGER.error("Failed to create bookmark directory: {}", bookmarkDir);
                throw new IOException("Failed to create bookmark directory: " + bookmarkDir);
            }
        }
        
        File bookmarkFile = new File(bookmarkDir, BOOKMARK_FILE);
        LOGGER.debug("Saving bookmark to: {}", bookmarkFile.getAbsolutePath());
        try (OutputStream os = new FileOutputStream(bookmarkFile)) {
            props.store(os, "TODO Update Batch Processing Bookmark");
        } catch (IOException e) {
            LOGGER.error("Failed to save bookmark file: {}", bookmarkFile.getAbsolutePath(), e);
            throw e;
        }
    }
