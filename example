import com.example.sftplib.SftpConnection;

/**
 * Service that checks for a dangerous delete flag file at startup and clears all local directories if found.
 * This is a dangerous operation and should only be used in development or emergency situations.
 */
public class StartupCleanupService {
    
    private static final Logger LOGGER = LogManager.getLogger(StartupCleanupService.class);
    private static final String DANGEROUS_DELETE_FLAG_FILE = "_DANGEROUSLY_DELETE_ALL_LOCAL_FILES_";
    private static final String DANGEROUS_DELETE_REMOTE_FLAG_FILE = "_DANGEROUSLY_DELETE_ALL_REMOTE_FILES_";
    
    private final TodoUpdBatchConfiguration config;
    
    public StartupCleanupService(TodoUpdBatchConfiguration config) {
        this.config = config;
    }
    
    /**
     * Check for the dangerous delete flag file and perform cleanup if found.
     * @return true if cleanup was performed, false otherwise
     */
    public boolean checkAndPerformCleanup() {
        // Check multiple locations for the flag file
        List<File> flagLocations = new ArrayList<>();
        
        // Check in current working directory
        flagLocations.add(new File(DANGEROUS_DELETE_FLAG_FILE));
        
        // Check in the local SFTP directory
        if (config.getLocalSftpDir() != null) {
            flagLocations.add(new File(config.getLocalSftpDir(), DANGEROUS_DELETE_FLAG_FILE));
        }
        
        // Check in the output directory
        if (config.getOutputDir() != null) {
            flagLocations.add(new File(config.getOutputDir(), DANGEROUS_DELETE_FLAG_FILE));
        }
        
        // Look for the flag file in any of these locations
        File foundFlagFile = null;
        for (File flagFile : flagLocations) {
            if (flagFile.exists()) {
                foundFlagFile = flagFile;
                LOGGER.warn("DANGEROUS DELETE FLAG FILE FOUND at: {}", flagFile.getAbsolutePath());
                break;
            }
        }
        
        if (foundFlagFile == null) {
            LOGGER.debug("No dangerous delete flag file found, proceeding normally");
            return false;
        }
        
        // Perform the dangerous cleanup
        LOGGER.warn("-----------------------------------------------");
        LOGGER.warn("PERFORMING DANGEROUS CLEANUP OF ALL LOCAL FILES");
        LOGGER.warn("This will delete all files in configured local directories!");
        LOGGER.warn("-----------------------------------------------");
        
        boolean cleanupSuccessful = true;
        
        // Clean up each configured directory
        List<String> directoriesToClean = new ArrayList<>();
        
        if (config.getLocalSftpDir() != null) {
            directoriesToClean.add(config.getLocalSftpDir());
        }
        if (config.getOutputDir() != null) {
            directoriesToClean.add(config.getOutputDir());
        }
        if (config.getBookmarkDir() != null) {
            directoriesToClean.add(config.getBookmarkDir());
        }
        if (config.getTodoFileFilesDir() != null) {
            directoriesToClean.add(config.getTodoFileFilesDir());
        }
        if (config.getBatchReportingApiOutputDirectory() != null && config.isEnableBatchReportingApi()) {
            directoriesToClean.add(config.getBatchReportingApiOutputDirectory());
        }
        
        for (String dirPath : directoriesToClean) {
            try {
                cleanDirectory(dirPath);
                LOGGER.warn("Cleaned directory: {}", dirPath);
            } catch (IOException e) {
                LOGGER.error("Failed to clean directory: {}", dirPath, e);
                cleanupSuccessful = false;
            }
        }
        
        // Delete the flag file itself
        try {
            if (foundFlagFile.delete()) {
                LOGGER.warn("Deleted flag file: {}", foundFlagFile.getAbsolutePath());
            } else {
                LOGGER.error("Failed to delete flag file: {}", foundFlagFile.getAbsolutePath());
                cleanupSuccessful = false;
            }
        } catch (Exception e) {
            LOGGER.error("Error deleting flag file: {}", foundFlagFile.getAbsolutePath(), e);
            cleanupSuccessful = false;
        }
        
        if (cleanupSuccessful) {
            LOGGER.warn("DANGEROUS CLEANUP COMPLETED SUCCESSFULLY");
        } else {
            LOGGER.error("DANGEROUS CLEANUP COMPLETED WITH ERRORS");
        }
        
        return cleanupSuccessful;
    }
    
    /**
     * Clean all files from a directory (but keep the directory itself).
     */
    private void cleanDirectory(String dirPath) throws IOException {
        Path directory = Paths.get(dirPath);
        
        if (!Files.exists(directory)) {
            LOGGER.debug("Directory does not exist, nothing to clean: {}", dirPath);
            return;
        }
        
        if (!Files.isDirectory(directory)) {
            LOGGER.warn("Path is not a directory, skipping: {}", dirPath);
            return;
        }
        
        // Delete all files and subdirectories recursively
        Files.walk(directory)
            .sorted(Comparator.reverseOrder()) // Delete files before directories
            .forEach(path -> {
                if (!path.equals(directory)) { // Don't delete the directory itself
                    try {
                        Files.delete(path);
                        LOGGER.debug("Deleted: {}", path);
                    } catch (IOException e) {
                        LOGGER.error("Failed to delete: {}", path, e);
                    }
                }
            });
    }
    
    /**
     * Check for the dangerous delete remote files flag and perform cleanup if found.
     * @param sftpService the SFTP service to use for remote operations
     * @return true if cleanup was performed, false otherwise
     */
    public boolean checkAndPerformRemoteCleanup(SftpService sftpService) {
        // Check multiple locations for the flag file
        List<File> flagLocations = new ArrayList<>();
        
        // Check in current working directory
        flagLocations.add(new File(DANGEROUS_DELETE_REMOTE_FLAG_FILE));
        
        // Check in the local SFTP directory
        if (config.getLocalSftpDir() != null) {
            flagLocations.add(new File(config.getLocalSftpDir(), DANGEROUS_DELETE_REMOTE_FLAG_FILE));
        }
        
        // Check in the output directory
        if (config.getOutputDir() != null) {
            flagLocations.add(new File(config.getOutputDir(), DANGEROUS_DELETE_REMOTE_FLAG_FILE));
        }
        
        // Look for the flag file in any of these locations
        File foundFlagFile = null;
        for (File flagFile : flagLocations) {
            if (flagFile.exists()) {
                foundFlagFile = flagFile;
                LOGGER.warn("DANGEROUS DELETE REMOTE FILES FLAG FOUND at: {}", flagFile.getAbsolutePath());
                break;
            }
        }
        
        if (foundFlagFile == null) {
            LOGGER.debug("No dangerous delete remote files flag found, proceeding normally");
            return false;
        }
        
        // Perform the dangerous remote cleanup
        LOGGER.warn("-----------------------------------------------");
        LOGGER.warn("PERFORMING DANGEROUS CLEANUP OF ALL REMOTE FILES");
        LOGGER.warn("This will delete all files in configured remote directories!");
        LOGGER.warn("-----------------------------------------------");
        
        boolean cleanupSuccessful = true;
        
        // Use try-with-resources to ensure connection is properly closed
        try (SftpConnection connection = sftpService.connect()) {
            
            // Clean up remote directories based on configuration
            List<String> remoteDirectoriesToClean = new ArrayList<>();
            
            // TYPE1 directories
            if (config.getType1RemoteBaseDir() != null) {
                remoteDirectoriesToClean.add(config.getType1RemoteBaseDir() + "/incoming");
                remoteDirectoriesToClean.add(config.getType1RemoteBaseDir() + "/input_archive");
                remoteDirectoriesToClean.add(config.getType1RemoteBaseDir() + "/output_archive");
            }
            
            // TYPE2 directories
            if (config.getType2RemoteBaseDir() != null) {
                remoteDirectoriesToClean.add(config.getType2RemoteBaseDir() + "/incoming");
                remoteDirectoriesToClean.add(config.getType2RemoteBaseDir() + "/input_archive");
                remoteDirectoriesToClean.add(config.getType2RemoteBaseDir() + "/output_archive");
            }
            
            // BATCHREPORTING output directory
            if (config.getRemoteBatchReportingOutputDirectory() != null) {
                remoteDirectoriesToClean.add(config.getRemoteBatchReportingOutputDirectory());
            }
            
            // Clean files from each remote directory
            for (String remotePath : remoteDirectoriesToClean) {
                try {
                    cleanRemoteDirectory(sftpService, connection, remotePath);
                    LOGGER.warn("Cleaned remote directory: {}", remotePath);
                } catch (Exception e) {
                    LOGGER.error("Failed to clean remote directory: {}", remotePath, e);
                    cleanupSuccessful = false;
                }
            }
            
        } catch (Exception e) {
            LOGGER.error("Error during remote cleanup", e);
            cleanupSuccessful = false;
        }
        
        // Delete the flag file itself
        try {
            if (foundFlagFile.delete()) {
                LOGGER.warn("Deleted flag file: {}", foundFlagFile.getAbsolutePath());
            } else {
                LOGGER.error("Failed to delete flag file: {}", foundFlagFile.getAbsolutePath());
                cleanupSuccessful = false;
            }
        } catch (Exception e) {
            LOGGER.error("Error deleting flag file: {}", foundFlagFile.getAbsolutePath(), e);
            cleanupSuccessful = false;
        }
        
        if (cleanupSuccessful) {
            LOGGER.warn("DANGEROUS REMOTE CLEANUP COMPLETED SUCCESSFULLY");
        } else {
            LOGGER.error("DANGEROUS REMOTE CLEANUP COMPLETED WITH ERRORS");
        }
        
        return cleanupSuccessful;
    }
    
    /**
     * Clean all files from a remote directory (but keep the directory itself).
     */
    private void cleanRemoteDirectory(SftpService sftpService, SftpConnection connection, 
                                     String remotePath) throws Exception {
        try {
            // List all files in the remote directory
            List<String> files = sftpService.listFiles(connection, remotePath);
            
            if (files == null || files.isEmpty()) {
                LOGGER.debug("No files found in remote directory: {}", remotePath);
                return;
            }
            
            LOGGER.info("Found {} files to delete in remote directory: {}", files.size(), remotePath);
            
            // Delete each file (not directories)
            for (String file : files) {
                // Skip directory entries
                if (file.equals(".") || file.equals("..")) {
                    continue;
                }
                
                String fullPath = remotePath + "/" + file;
                try {
                    // Check if it's a directory by trying to list its contents
                    // If it throws an exception, it's likely a file
                    try {
                        sftpService.listFiles(connection, fullPath);
                        LOGGER.debug("Skipping directory: {}", fullPath);
                        continue;
                    } catch (Exception e) {
                        // Not a directory, proceed with deletion
                    }
                    
                    sftpService.delete(connection, fullPath);
                    LOGGER.debug("Deleted remote file: {}", fullPath);
                } catch (Exception e) {
                    LOGGER.error("Failed to delete remote file: {}", fullPath, e);
                    throw e;
                }
            }
        } catch (Exception e) {
            LOGGER.error("Error cleaning remote directory: {}", remotePath, e);
            throw e;
        }
    }
