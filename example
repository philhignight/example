    /**
     * Generates EXAMPLE_FRAMEWORK instruction XML for an TODO update request.
     * 
     * @param record TODO update record
     * @return EXAMPLE_FRAMEWORK instruction XML
     */
    private String generateExampleFrameworkInstructionXml(TodoUpdateRecord record) {
        StringBuilder xml = new StringBuilder();
        xml.append("<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n");
        xml.append("<ExchangeMessage>\n");
        xml.append("  <headers>\n");
        xml.append("    <Security productId=\"" + Constants.EXAMPLE_FRAMEWORK_PRODUCT_ID
                + "\" runId=\"0\" siteId=\"0\" userId=\"0\"/>\n");
        xml.append("  </headers>\n");
        xml.append("  <hints>\n");
        xml.append("    <Hint exampleframeworkSource=\"U\" instructionTypeCode=\"push\" pullType=\"family\"/>\n");
        xml.append("  </hints>\n");
        xml.append("  <inputs>\n");
        xml.append("    <AdminstrBUSINESSOBJECT subjectUpdateCode=\"N\">\n");
        xml.append("      <PersonIdentityBUSINESSOBJECT\n");
        xml.append("        personId=\"" + record.getOldAdminstrId() + "\"\n");
        xml.append("        personIdTypeCode=\"" + record.getOldAdminstrIdType() + "\"\n");
        xml.append("        personLastName=\"" + record.getLastName() + "\"\n");
        xml.append("      />\n");
        xml.append("      <IdentityChangeBUSINESSOBJECT\n");
        xml.append("        personId=\"" + record.getNewAdminstrId() + "\"\n");
        xml.append("        personIdTypeCode=\"" + record.getNewAdminstrIdType() + "\"\n");
        xml.append("        subjectUpdateCode=\"M\"\n");
        xml.append("      />\n");
        xml.append("    </AdminstrBUSINESSOBJECT>\n");
        xml.append("  </inputs>\n");
        xml.append("</ExchangeMessage>");
        return xml.toString();
    }

