public class TodoUpdBatchService {
    private static final Logger LOGGER = LogManager.getLogger(TodoUpdBatchService.class);

    private final SftpService sftpService;
    private final SftpConnection sftpConnection;
    private final TimeProvider timeProvider;
    private final FileSystemProvider fileSystemProvider;
    private final ThreadProvider threadProvider;

    public TodoUpdBatchService(final SftpService sftpService, final SftpConnection sftpConnection) {
        this(sftpService, sftpConnection, new TimeProvider(), new FileSystemProvider(), new ThreadProvider());
    }
    
    public TodoUpdBatchService(final SftpService sftpService, 
                             final SftpConnection sftpConnection,
                             final TimeProvider timeProvider,
                             final FileSystemProvider fileSystemProvider,
                             final ThreadProvider threadProvider) {
        if (sftpService == null) {
            throw new IllegalArgumentException("sftpService is required");
        }

        if (sftpConnection == null) {
            throw new IllegalArgumentException("sftpConnection is required");
        }

        this.sftpService = sftpService;
        this.sftpConnection = sftpConnection;
        this.timeProvider = timeProvider;
        this.fileSystemProvider = fileSystemProvider;
        this.threadProvider = threadProvider;
    }

    // Check to ensure the directories are clean (ready for a new input file)
    public boolean areDirectoriesCleanForNewFile(final String localSftpDir) {
        if (Utils.isEmpty(localSftpDir)) {
            throw new IllegalArgumentException("localSftpDir is required");
        }

        // Ensure the localSftpDir is empty, but ignore files that start with a "."
        // because NFS sometimes creates those.
        final File localSftpDirectory = toFile(localSftpDir);
        if (!localSftpDirectory.isDirectory()) {
            throw new IllegalArgumentException("localSftpDir is not a directory");
        }

        if (doesDirectoryContainAnyFilesExcludingHiddenFiles(localSftpDirectory)) {
            LOGGER.error("Cannot start processing new input file because local sftp directory (" + localSftpDir
                    + ") is not empty.");
            return false;
        }

        return true;
    }

    // Get the next input file for processing
    public Optional<File> getNextInputFile(final String remoteInputFilePath, final String remoteInputFilePattern,
            final String localPath) throws IOException, GeneralSecurityException {
        if (Utils.isEmpty(remoteInputFilePath)) {
            throw new IllegalArgumentException("remoteInputFilePath is required");
        }
        if (Utils.isEmpty(remoteInputFilePattern)) {
            throw new IllegalArgumentException("remoteInputFilePattern is required");
        }
        if (Utils.isEmpty(localPath)) {
            throw new IllegalArgumentException("localPath is required");
        }

        String localInputFile = null;
        String remoteFileName = null;
        String remoteFilePath = null;

        List<String> remoteFiles = new ArrayList<String>();
        try {
            LOGGER.debug("Getting list of files from SFTP " + remoteInputFilePath + "/" + remoteInputFilePattern);
            remoteFiles = sftpService.listFiles(sftpConnection, remoteInputFilePath + "/" + remoteInputFilePattern);
        } catch (final SftpException | IOException | GeneralSecurityException e) {
            LOGGER.error("Error getting list of files from SFTP " + remoteInputFilePath + "/" + remoteInputFilePattern,
                    e);
            throw e;
        }

        if (remoteFiles != null && !remoteFiles.isEmpty()) {
            // By default the SFTP files are listed alphabetically by name (which is what we
            // want).
            // Just get the first file in the list.
            remoteFileName = remoteFiles.get(0);

            // Get the full path name of the local file (retaining the original file name)
            localInputFile = localPath + "/" + (new File(remoteFileName)).getName();
            remoteFilePath = remoteInputFilePath + "/" + remoteFileName;

            try {
                sftpService.get(sftpConnection, remoteFilePath, localInputFile);
            } catch (final SftpException | IOException | GeneralSecurityException e) {
                LOGGER.error("Error getting remote file " + remoteFilePath + " using SFTP to local " + localInputFile,
                        e);
                // Delete the remoteInputFilePath + "/" + remoteFileName
                throw e;
            }

            LOGGER.debug("Successfully transferred " + remoteInputFilePath + "/" + remoteFileName + " to local "
                    + localInputFile);
        }

        return Optional.ofNullable((localInputFile == null) ? null : new File(localInputFile));
    }

    public void moveRemoteFile(String sourceFilename, String destinationFilename)
            throws IOException, GeneralSecurityException {
        if (Utils.isEmpty(sourceFilename)) {
            throw new IllegalArgumentException("sourceFilename is required");
        }
        if (Utils.isEmpty(destinationFilename)) {
            throw new IllegalArgumentException("destinationFilename is required");
        }

        try {
            sftpService.rename(sftpConnection, sourceFilename, destinationFilename);
        } catch (final SftpException | IOException | GeneralSecurityException e) {
            LOGGER.error("Error moving remote file " + sourceFilename + " to " + destinationFilename, e);
            throw e;
        }

        LOGGER.info("Successfully moved remote file " + sourceFilename + " to " + destinationFilename);
    }

    public String getCurrentDateTime(final String formatStr) {
        return timeProvider.formatCurrentDate(formatStr);
    }

    // for mocking
    File toFile(final String filenamePath) {
        return fileSystemProvider.createFile(filenamePath);
    }

    boolean doesDirectoryContainAnyFilesExcludingHiddenFiles(final File file) throws IllegalArgumentException {
        if (!file.isDirectory()) {
            throw new IllegalArgumentException("file is not a directory");
        }

        return file.listFiles((d, name) -> !name.startsWith(".")).length > 0;
    }

    Path getPath(final String path) {
        return fileSystemProvider.getPath(path);
    }

    String readFirstLineOfFile(final File inputFile) throws IOException {
        return fileSystemProvider.readFirstLine(inputFile.toPath());
    }

    String readStringFromPath(final Path path) throws IOException {
        return fileSystemProvider.readFileContent(path);
    }

    void sleep(final int sleepTime) throws InterruptedException {
        threadProvider.sleep(sleepTime);
    }
