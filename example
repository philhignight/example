    public ExchangeMessage sendTodoUpdateRequest(TodoUpdateRecord record, String stopFilePath) 
            throws IOException, StopException {
        // Generate EXAMPLE_FRAMEWORK instruction XML
        String instructionXml = generateExampleFrameworkInstructionXml(record);
        // Send to EXAMPLE_FRAMEWORK with record-level retries for transient errors
        return sendToExampleFrameworkWithRecordLevelRetries(instructionXml, stopFilePath);
