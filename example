            exampleframeworkResult.getValidationErrors()));
        
        // Add EXAMPLE_FRAMEWORK errors
        errorRecords.addAll(recordFormatter.formatExampleFrameworkErrors(
            exampleframeworkResult.getExampleFrameworkErrors()));
        
