        public TodoUpdateRecord getRecord() { return record; }
        public ExampleFrameworkResponseData getResponseData() { return responseData; }
    }
    
    /**
     * Process records through EXAMPLE_FRAMEWORK phase.
     */
    public ExampleFrameworkPhaseResult processExampleFrameworkPhase(List<TodoUpdateRecord> records,
                                         String todoFile,
                                         String todoFilePrefix,
                                         String stopFilePath,
                                         BookmarkService bookmarkService,
                                         int startingLine) throws IOException, StopException {
        
        LOGGER.info("Starting EXAMPLE_FRAMEWORK phase processing from line {} of {} records", 
            startingLine, records.size());
        
        List<ExampleFrameworkResponseData> successfulResponses = new ArrayList<>();
        List<ValidationError> validationErrors = new ArrayList<>();
        List<ExampleFrameworkError> exampleframeworkErrors = new ArrayList<>();
        
        for (int i = startingLine; i < records.size(); i++) {
            TodoUpdateRecord record = records.get(i);
            int lineNumber = i + 1;
            
            try {
                // Validate record
                RecordValidator.ValidationResult validationResult = 
                    recordValidator.validateRecord(record, records);
                
                if (validationResult != null) {
                    LOGGER.debug("Record at line {} failed validation: {}", 
                        lineNumber, validationResult.getDescription());
                    validationErrors.add(new ValidationError(record, validationResult));
                    
                    // Save validation error to response file for BATCHREPORTING processing
                    ExampleFrameworkResponseData errorData = new ExampleFrameworkResponseData(
                        record, lineNumber, 
                        validationResult.getOldReturnCode(), 
                        validationResult.getDescription()
                    );
                    responseFileService.writeExampleFrameworkResponse(errorData, todoFile, todoFilePrefix);
                } else {
                    // Send to EXAMPLE_FRAMEWORK
                    ExampleFrameworkResponseData responseData = sendToExampleFramework(record, stopFilePath, lineNumber, 
                        todoFile, todoFilePrefix);
                    
                    if ("0".equals(responseData.getReturnCode())) {
                        successfulResponses.add(responseData);
                    } else {
                        exampleframeworkErrors.add(new ExampleFrameworkError(record, responseData));
                    }
                }
                
                // Update bookmark progress
                if (bookmarkService != null) {
                    try {
                        bookmarkService.updateProgress(i + 1);
                    } catch (IOException e) {
                        LOGGER.warn("Failed to update bookmark progress", e);
                    }
                }
                
            } catch (StopException e) {
                LOGGER.info("Stop requested during EXAMPLE_FRAMEWORK processing at line {}", lineNumber);
                throw e;
            } catch (Exception e) {
                LOGGER.error("Unexpected error processing record at line {}", lineNumber, e);
                
                // Create error response data
                ExampleFrameworkResponseData errorData = new ExampleFrameworkResponseData(
                    record, lineNumber,
                    "2", // System error code
                    "Unexpected error: " + e.getMessage()
                );
                responseFileService.writeExampleFrameworkResponse(errorData, todoFile, todoFilePrefix);
                exampleframeworkErrors.add(new ExampleFrameworkError(record, errorData));
            }
        }
        
        LOGGER.info("EXAMPLE_FRAMEWORK phase completed. Success: {}, Validation errors: {}, EXAMPLE_FRAMEWORK errors: {}", 
            successfulResponses.size(), validationErrors.size(), exampleframeworkErrors.size());
        
        return new ExampleFrameworkPhaseResult(successfulResponses, validationErrors, exampleframeworkErrors, records.size());
    }
    
    /**
     * Send a single record to EXAMPLE_FRAMEWORK and capture the response.
     */
    private ExampleFrameworkResponseData sendToExampleFramework(TodoUpdateRecord record, String stopFilePath, 
                                     int lineNumber, String todoFile, 
                                     String todoFilePrefix) 
                                     throws IOException, StopException {
        
        LOGGER.debug("Sending record to EXAMPLE_FRAMEWORK for line {}", lineNumber);
        ExchangeMessage response = exampleframeworkService.sendTodoUpdateRequest(record, stopFilePath);
        
        // Extrtype1 response details
        String returnCode = "0";
        String statusCode = "00000"; 
        String errorMessage = "";
        
        if (response != null) {
            IFrameworkStatus exampleframeworkStatus = response.getStatus();
            if (exampleframeworkStatus != null) {
                List<IFrameworkStatusDetail> statusDetails = exampleframeworkStatus.getStatusDetails();
                if (statusDetails != null && !statusDetails.isEmpty()) {
                    IFrameworkStatusDetail detail = statusDetails.get(0);
                    returnCode = detail.getSystemReturnCode();
                    statusCode = detail.getSystemReturnStatusCode();
                    errorMessage = detail.getExampleFrameworkExceptionMessage() != null ? 
                        detail.getExampleFrameworkExceptionMessage().replaceAll("[\r\n]+", " ") : "";
                }
            }
        }
        
        // Create response data using the ExchangeMessage constructor
        ExampleFrameworkResponseData responseData = new ExampleFrameworkResponseData(record, lineNumber, response);
        
        // Save to file for BATCHREPORTING phase
        responseFileService.writeExampleFrameworkResponse(responseData, todoFile, todoFilePrefix);
        
        return responseData;
    }
