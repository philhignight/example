        public ExampleFrameworkError(TodoUpdateRecord record, ExampleFrameworkResponseData responseData) {
            this.record = record;
            this.responseData = responseData;
        }
        
        public TodoUpdateRecord getRecord() { return record; }
        public ExampleFrameworkResponseData getResponseData() { return responseData; }
