        assertNull(validator.validateRecord(record1, processedRecords));
        processedRecords.add(record1);
        
        // Second record: B -> A (reversal)
        TodoUpdateRecord record2 = createRecord("222222222", "S", "111111111", "S");
        RecordValidator.ValidationResult result = validator.validateRecord(record2, processedRecords);
        
        assertNotNull(result);
        assertEquals("304", result.getAltPrcId());  // Error code should be in prcCntrSeqId
