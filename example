        final String applicationName = propertyProvider.getProperty(PROP_APP_NAME);
        final String myorgRegion = propertyProvider.getProperty(PROP_MYORG_REGION);
        final Event event = createEvent(EventType.APPLICATION_SHUTDOWN);

        event.addAttribute("appVersion", packageInfoProvider.getImplementationVersion(getClass()));
        event.addAttribute("appName", applicationName);
        event.addAttribute("deviceExternalId", myorgRegion);
        event.log();
    }

    Event createEvent(final EventType eventType) {
        return Event.build(eventType);
    }
