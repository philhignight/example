package com.example.todoapp.util;

import java.io.File;
import java.io.IOException;

/**
 * Utility class for validating file paths to prevent path traversal attacks.
 */
public class PathValidator {
    
    /**
     * Validates that a filename does not contain path traversal sequences.
     * 
     * @param filename the filename to validate
     * @throws SecurityException if the filename contains invalid chartype1ers
     */
    public static void validateFilename(String filename) throws SecurityException {
        if (filename == null || filename.isEmpty()) {
            throw new SecurityException("Filename cannot be null or empty");
        }
        
        if (filename.contains("..") || filename.contains("/") || filename.contains("\\")) {
            throw new SecurityException("Invalid filename: " + filename);
        }
    }
    
    /**
     * Validates that a directory path does not contain path traversal sequences.
     * 
     * @param directoryPath the directory path to validate
     * @throws SecurityException if the path contains invalid sequences
     */
    public static void validateDirectoryPath(String directoryPath) throws SecurityException {
        if (directoryPath == null || directoryPath.isEmpty()) {
            throw new SecurityException("Directory path cannot be null or empty");
        }
        
        if (directoryPath.contains("..")) {
            throw new SecurityException("Invalid directory path: contains parent directory reference");
        }
    }
    
    /**
     * Validates that a file path stays within the specified base directory.
     * 
     * @param baseDir the base directory that files should stay within
     * @param filePath the file path to validate
     * @return the canonical path of the file
     * @throws IOException if there's an error resolving the canonical path
     * @throws SecurityException if the file path escapes the base directory
     */
    public static String validatePathWithinDirectory(String baseDir, String filePath) 
            throws IOException, SecurityException {
        File baseDirFile = new File(baseDir);
        File file = new File(filePath);
        
        String baseDirCanonical = baseDirFile.getCanonicalPath();
        String fileCanonical = file.getCanonicalPath();
        
        if (!fileCanonical.startsWith(baseDirCanonical)) {
            throw new SecurityException("Path traversal attempt detected: " + filePath);
        }
        
        return fileCanonical;
    }
    
    /**
     * Safely constructs a file path by validating the filename and combining it with the directory.
     * 
     * @param directory the directory path
     * @param filename the filename to append
     * @return the canonical path of the combined file
     * @throws IOException if there's an error resolving the canonical path
     * @throws SecurityException if the filename or resulting path is invalid
     */
    public static String safePathCombine(String directory, String filename) 
            throws IOException, SecurityException {
        validateFilename(filename);
        
        File dir = new File(directory);
        File file = new File(dir, filename);
        
        String dirCanonical = dir.getCanonicalPath();
        String fileCanonical = file.getCanonicalPath();
        
        if (!fileCanonical.startsWith(dirCanonical)) {
            throw new SecurityException("Path traversal attempt detected");
        }
        
        return fileCanonical;
    }
