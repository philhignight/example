public class Utils {
    private Utils() {}

    public static boolean toBoolean(String str) {
        return "true".equalsIgnoreCase(str);
    }

    public static int parseInt(final String test, final int defaultValue) {
        if (test == null || test.trim().isEmpty()) {
            return defaultValue;
        }

        try {
            return Integer.parseInt(test.trim());
        } catch (NumberFormatException e) {
            return defaultValue;
        }
    }

    public static long parseLong(final String test, final long defaultValue) {
        if (test == null || test.trim().isEmpty()) {
            return defaultValue;
        }

        try {
            return Long.parseLong(test.trim());
        } catch (NumberFormatException e) {
            return defaultValue;
        }
    }

    public static String empty(final String str, final String alt) {
        return str == null || str.trim().isEmpty() ? alt : str.trim();
    }

    public static boolean isEmpty(final String str) {
        return str == null || str.trim().isEmpty();
    }

    public static boolean isAllNumeric(final String value) {
        return !isEmpty(value) && value.trim().matches("^\\d+$");
    }

    public static boolean isValidDate(final String dateStr, final boolean allowAll9orAll0) {
        if (dateStr == null) {
            return false;
        }

        if (allowAll9orAll0) {
            if ("99999999".equals(dateStr) || "00000000".equals(dateStr)) {
                return true;
            }
        }

        // yyyyMMdd
        try {
            DateTimeFormatter.BASIC_ISO_DATE.parse(dateStr);
            return true;
        } catch (DateTimeParseException e) {
            return false;
        }
    }

    /**
     * checks {@code timeStr} is valid {@code HHmmss} representation of time
     * 
     * @param timeStr
     * @return
     */
    public static boolean isValidTime(final String timeStr) {
        if (timeStr == null) {
            return false;
        }
        
        // yyyyMMdd
        try {
            DateTimeFormatter.ofPattern("HHmmss").parse(timeStr);
            return true;
        } catch (DateTimeParseException e) {
            return false;
        }
    }

    public static String leftPad(final String padding, final int length, final String str) {
        String b = str == null ? "" : str;

        while (b.length() < length) {
            b = padding + b;
        }

        return b;
    }

    public static String rightPad(final String padding, final int length, final String str) {
        String b = str == null ? "" : str;

        while (b.length() < length) {
            b = b + padding;
        }

        return b;
    }

    public static String replaceNewlines(String input) {
        return input != null ? input.replaceAll("[\r\n]+", " ") : null;
    }

    /**
     * if {@code str} is null or blank, return empty string.
     * <p>
     * otherwise pad {@code str} with {@code padding} to reach {@code length}.
     * 
     * If {@code padLeft} is true, the padding is on the left, else it's on the right.
     * <p>
     * if {@code str} is longer than {@code length} then truncate to {@code length}
     * <p>
     * 
     * @param padding
     * @param length
     * @param padLeft
     * @param str
     * @return
     */
    public static String formatError(final String padding, final int length, final boolean padLeft, final String str) {
        if (str == null || str.trim().isEmpty()) {
            return "";
        }

        String b;

        if (padLeft) {
            b = leftPad(padding, length, str);
        } else {
            // right pad
            b = str;

            while (b.length() < length) {
                b = b + padding;
            }
        }

        if (b.length() > length) {
            b = b.substring(0, length);
        }

        return b;
    }

    public static String formatDollarAmount(final String ammount, int length) {
        // modernized code
        final int amountInt = parseInt(ammount, 0);
        if (amountInt == 0) {
            return "$" + leftPad("0", length - 4, "0") + ".00";
        }

        final int dollarAmount = amountInt / 100;

        return "$" + leftPad("0", length - 4, "" + dollarAmount) + "." + String.format("%02d", amountInt % 100);
    }

