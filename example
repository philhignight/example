/**
 * Test for two-phase EXAMPLE_FRAMEWORK/BATCHREPORTING processing with JSONL intermediate storage.
 */
public class TwoPhaseProcessingTest {
    
    private static final String TEST_OUTPUT_DIR = "build/test-output";
    private ExampleFrameworkResponseFileService exampleframeworkResponseFileService;
    
    @BeforeEach
    public void setUp() throws IOException {
        // Create test output directory
        Files.createDirectories(Paths.get(TEST_OUTPUT_DIR));
        exampleframeworkResponseFileService = new ExampleFrameworkResponseFileService(TEST_OUTPUT_DIR);
    }
    
    @AfterEach
    public void tearDown() throws IOException {
        // Clean up test files
        File dir = new File(TEST_OUTPUT_DIR);
        if (dir.exists()) {
            File[] files = dir.listFiles();
            if (files != null) {
                for (File file : files) {
                    file.delete();
                }
            }
            dir.delete();
        }
    }
    
    @Test
    public void testExampleFrameworkResponseFileSerialization() throws IOException {
        // Create test EXAMPLE_FRAMEWORK response data
        ExampleFrameworkResponseData response1 = new ExampleFrameworkResponseData();
        response1.setLineNumber(1);
        response1.setOriginalLine("TEST_LINE_1");
        response1.setOldAdminstrId("123456789");
        response1.setOldAdminstrIdType("S");
        response1.setNewAdminstrId("987654321");
        response1.setNewAdminstrIdType("P");
        response1.setSuccess(true);
        response1.setReturnStatusCode("0");
        response1.setReturnReasonCode("0");
        
        ExampleFrameworkResponseData response2 = new ExampleFrameworkResponseData();
        response2.setLineNumber(2);
        response2.setOriginalLine("TEST_LINE_2");
        response2.setOldAdminstrId("111111111");
        response2.setOldAdminstrIdType("S");
        response2.setNewAdminstrId("222222222");
        response2.setNewAdminstrIdType("P");
        response2.setSuccess(false);
        response2.setReturnStatusCode("1");
        response2.setReturnReasonCode("E001");
        response2.setValidationError(true);
        response2.setValidationErrorCode("VAL001");
        response2.setValidationDescription("Invalid ID format");
        
        // Write responses to JSONL file
        String todoFile = "12345";
        String todoFilePrefix = "TYPE1CODE";
        
        exampleframeworkResponseFileService.writeExampleFrameworkResponse(response1, todoFile, todoFilePrefix);
        exampleframeworkResponseFileService.writeExampleFrameworkResponse(response2, todoFile, todoFilePrefix);
        
        // Verify file exists
        assertTrue(exampleframeworkResponseFileService.exampleframeworkResponseFileExists(todoFile, todoFilePrefix),
            "EXAMPLE_FRAMEWORK response file should exist");
        
        // Read responses back
        List<ExampleFrameworkResponseData> readResponses = exampleframeworkResponseFileService.readAllExampleFrameworkResponses(
            todoFile, todoFilePrefix);
        
        // Verify data
        assertEquals(2, readResponses.size(), "Should have 2 responses");
        
        ExampleFrameworkResponseData read1 = readResponses.get(0);
        assertEquals(1, read1.getLineNumber());
        assertEquals("123456789", read1.getOldAdminstrId());
        assertEquals("987654321", read1.getNewAdminstrId());
        assertTrue(read1.isSuccess());
        assertEquals("0", read1.getReturnStatusCode());
        
        ExampleFrameworkResponseData read2 = readResponses.get(1);
        assertEquals(2, read2.getLineNumber());
        assertEquals("111111111", read2.getOldAdminstrId());
        assertEquals("222222222", read2.getNewAdminstrId());
        assertFalse(read2.isSuccess());
        assertTrue(read2.isValidationError());
        assertEquals("VAL001", read2.getValidationErrorCode());
    }
    
    @Test
    public void testReadFromLine() throws IOException {
        // Write 5 responses
        String todoFile = "67890";
        String todoFilePrefix = "TYPE2CODE";
        
        for (int i = 1; i <= 5; i++) {
            ExampleFrameworkResponseData response = new ExampleFrameworkResponseData();
            response.setLineNumber(i);
            response.setOriginalLine("LINE_" + i);
            response.setOldAdminstrId("OLD_" + i);
            response.setNewAdminstrId("NEW_" + i);
            response.setSuccess(true);
            exampleframeworkResponseFileService.writeExampleFrameworkResponse(response, todoFile, todoFilePrefix);
        }
        
        // Read from line 3
        List<ExampleFrameworkResponseData> fromLine3 = exampleframeworkResponseFileService.readExampleFrameworkResponsesFromLine(
            todoFile, todoFilePrefix, 3);
        
        // Should only get lines 4 and 5
        assertEquals(2, fromLine3.size(), "Should have 2 responses after line 3");
        assertEquals(4, fromLine3.get(0).getLineNumber());
        assertEquals(5, fromLine3.get(1).getLineNumber());
    }
    
