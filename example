        public List<ExampleFrameworkResponseData> getSuccessfulResponses() { return successfulResponses; }
        public List<ValidationError> getValidationErrors() { return validationErrors; }
        public List<ExampleFrameworkError> getExampleFrameworkErrors() { return exampleframeworkErrors; }
        public int getTotalProcessed() { return totalProcessed; }
