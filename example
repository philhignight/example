            boolean hasStatements = lines.stream()
                .anyMatch(line -> {
                    String trimmed = line.trim();
                    return !trimmed.isEmpty() && !trimmed.startsWith("--") && !trimmed.startsWith("#");
                });
            
            if (hasStatements) {
                conn.setAutoCommit(false);
            }
            
            for (String line : lines) {
                line = line.trim();
                
                // Skip empty lines and comments
