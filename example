        this.batchreportingAdapter = batchreportingAdapter;
        this.fileSystemProvider = fileSystemProvider;
        this.timeProvider = timeProvider;
        this.idGenerator = idGenerator;
        this.exampleframeworkResponseFileService = serviceProvider.getExampleFrameworkResponseFileService();
    }
    
    /**
     * Process all configured types (TYPE1 and TYPE2).
     */
    public void processAllTypes() throws StopException {
        String[] types = { "TYPE1", "TYPE2" };
        
        for (String type : types) {
            try {
                processType(type);
            } catch (StopException e) {
                LOGGER.info("Stop requested while processing type: {}", type);
                throw e;
            } catch (Exception e) {
                LOGGER.error("Error processing type: " + type, e);
                // Continue with next type
            }
        }
    }
    
    /**
     * Process a specific type (TYPE1 or TYPE2).
     * Core orchestration logic extrtype1ed from TodoUpdBatchApplication.
     */
    private void processType(String type) throws StopException {
        LOGGER.debug("Starting processType for type {}", type);
        
        final boolean isType1iveDuty = "TYPE1".equals(type);
        final String todoFilePrefix = isType1iveDuty ? 
            Constants.TYPE1_TODO_FILE_PREFIX : Constants.TYPE2_TODO_FILE_PREFIX;
        
        // Setup directories based on type
        final String remoteBaseDir = isType1iveDuty ? 
            config.getType1RemoteBaseDir() : config.getType2RemoteBaseDir();
        final String incomingDir = remoteBaseDir + "/" + Constants.RELATIVE_INCOMING_DIR;
        final String inputArchiveDir = remoteBaseDir + "/" + Constants.RELATIVE_INPUT_ARCHIVE_DIR;
        final String outputArchiveDir = remoteBaseDir + "/" + Constants.RELATIVE_OUTPUT_ARCHIVE_DIR;
        
        // Check stop file
        if (shouldStop()) {
            throw new StopException();
        }
        
        // Check for recovery scenario
        RecoveryService recoveryService = serviceProvider.getRecoveryService();
        Optional<RecoveryService.RecoveryContext> recoveryOpt = recoveryService.determineRecoveryContext(type);
        
        if (recoveryOpt.isPresent()) {
            // Recovery scenario - use existing state
            RecoveryService.RecoveryContext recovery = recoveryOpt.get();
            LOGGER.info("Recovering from state: {} for type: {}", recovery.getStartState(), type);
            
            try (final SftpConnection sftpConnection = sftpService.connect()) {
                processFileWithRecovery(recovery, type, todoFilePrefix,
                    inputArchiveDir, outputArchiveDir, sftpConnection);
            } catch (StopException e) {
                throw e;
            } catch (Exception e) {
                LOGGER.error("Error during recovery for type: " + type, e);
                throw new RuntimeException("Failed during recovery for type: " + type, e);
            }
        } else {
            // Normal processing - no recovery needed
            try (final SftpConnection sftpConnection = sftpService.connect()) {
                LOGGER.info("Connected to SFTP for type: {}", type);
                
                // Create batch service with injected providers for testability
                final TodoUpdBatchService todoUpdService = new TodoUpdBatchService(
                    sftpService, sftpConnection, timeProvider, fileSystemProvider, 
                    new ThreadProvider());
                
                // Get next input file
                Optional<File> inputFileOpt = fileOps.getNextInputFile(
                    todoUpdService, incomingDir, Constants.INPUT_FILE_PATTERN, config.getLocalSftpDir());
                
                if (!inputFileOpt.isPresent()) {
                    LOGGER.debug("No input files found for type: {}", type);
                    return;
                }
                
                File inputFile = inputFileOpt.get();
                String retrievedFileName = incomingDir + "/" + inputFile.getName();
                LOGGER.info("Processing file: {} for type: {}", retrievedFileName, type);
                
                // Generate submission ID
                String todoFile = generateTodoFile(type);
                
                // Archive input file
                String inputFileArchiveName = String.format("todoapp-%s%s-input-%s.txt",
                    todoFilePrefix, todoFile, 
                    timeProvider.formatCurrentDate("yyyyMMdd"));
                fileOps.moveRemoteFile(todoUpdService, retrievedFileName, 
                    inputArchiveDir + "/" + inputFileArchiveName);
                
                // Process the file
                processFile(inputFile, type, todoFile, todoFilePrefix, 
                    outputArchiveDir, sftpConnection, ProcessingState.INPUT_FILE_ARCHIVED);
                
            } catch (StopException e) {
                throw e;
            } catch (Exception e) {
                LOGGER.error("Error processing type: " + type, e);
                throw new RuntimeException("Failed to process type: " + type, e);
            }
        }
    }
    
    /**
     * Process file with recovery context.
     */
    private void processFileWithRecovery(RecoveryService.RecoveryContext recovery,
                                       String type,
                                       String todoFilePrefix,
                                       String inputArchiveDir,
                                       String outputArchiveDir,
                                       SftpConnection sftpConnection)
                                       throws IOException, StopException, GeneralSecurityException {
        
        BookmarkService.BookmarkState bookmark = recovery.getBookmark();
        String todoFile = bookmark != null ? bookmark.getTodoFile() : generateTodoFile(type);
        File inputFile = recovery.getInputFile();
        
        // If we haven't archived the input file yet, do it now
        if (recovery.shouldSkip(ProcessingState.INPUT_FILE_ARCHIVED)) {
            LOGGER.info("Skipping input file archive - already completed");
        } else {
            String retrievedFileName = inputFile.getName();
            String inputFileArchiveName = String.format("todoapp-%s%s-input-%s.txt",
                todoFilePrefix, todoFile, 
                timeProvider.formatCurrentDate("yyyyMMdd"));
            
            TodoUpdBatchService todoUpdService = new TodoUpdBatchService(
                sftpService, sftpConnection, timeProvider, fileSystemProvider, 
                new ThreadProvider());
            
            fileOps.moveRemoteFile(todoUpdService, 
                config.getLocalSftpDir() + "/" + retrievedFileName, 
                inputArchiveDir + "/" + inputFileArchiveName);
        }
        
        // Process with appropriate starting state
        processFile(inputFile, type, todoFile, todoFilePrefix,
            outputArchiveDir, sftpConnection, recovery.getStartState());
    }
    
    /**
     * Process a single input file.
     */
    private void processFile(File inputFile, 
                           String type,
                           String todoFile,
                           String todoFilePrefix,
                           String outputArchiveDir,
                           SftpConnection sftpConnection,
                           ProcessingState startingState) 
                           throws IOException, StopException, GeneralSecurityException {
        
        BatchReportingApiKey batchreportingApiKey = null;
        BookmarkService bookmarkService = serviceProvider.getBookmarkService();
        long batchId = 0;
        BatchJobReport successReport = null;
        
        try {
            // Check if we need to recover batch ID from bookmark
            Optional<BookmarkService.BookmarkState> existingBookmark = bookmarkService.loadBookmark();
            if (existingBookmark.isPresent() && startingState != ProcessingState.NOT_STARTED) {
                // Recovering - use existing batch ID
                batchId = existingBookmark.get().getBatchId();
                successReport = new BatchJobReport(
                    "TODOUPDATE Batch", "01", String.valueOf(batchId), 
                    "0", "0", "/todoapp/batch-" + batchId, 
                    "This is a restarted job (recovery from interruption)");
                LOGGER.info("Recovering with existing batch ID: {}", batchId);
            } else {
                // Fresh start - generate new batch ID
                batchId = idGenerator.generateFakeDbfBatchId();
                successReport = new BatchJobReport(
                    "TODOUPDATE Batch", "01", String.valueOf(batchId), 
                    "0", "0", "/todoapp/batch-" + batchId, 
                    "This is not a restarted job (first time processing)");
            }
            
            // BATCHREPORTING will be initialized later, only when needed for BATCHREPORTING phase
            
            RecordProcessor.ProcessingResult result;
            
            if (!startingState.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED)) {
                LOGGER.info("Starting PHASE 1: EXAMPLE_FRAMEWORK Processing");
                
                // Load all records into memory for validation
                List<String> lines = fileService.readLines(inputFile);
                LOGGER.info("Loaded {} records from input file", lines.size());
                
                // Parse all records
                List<TodoUpdateRecord> records = new ArrayList<>();
                for (int i = 0; i < lines.size(); i++) {
                    TodoUpdateRecord record = RecordParser.parseRecord(lines.get(i), type);
                    record.setLineNumber(i + 1);
                    records.add(record);
                }
                
                // Create or update bookmark
                if (!bookmarkService.bookmarkExists()) {
                    bookmarkService.createBookmark(todoFile, batchId, 
                        inputFile.getAbsolutePath(), records.size(), type);
                }
                
                // Update status to EXAMPLE_FRAMEWORK_PROCESSING if not already in that state
                if (!startingState.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING)) {
                    bookmarkService.updateStatus(ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING);
                }
                
                // Determine starting position for recovery
                int recordOffset = 0;
                if (startingState.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING) && existingBookmark.isPresent()) {
                    recordOffset = existingBookmark.get().getLastCompletedLine();
                    LOGGER.info("Resuming from record {} of {}", recordOffset + 1, records.size());
                }
                
                // Configure record processor for recovery and two-phase processing
                recordProcessor.setBookmarkTracking(bookmarkService, recordOffset);
                recordProcessor.setExampleFrameworkResponseFileService(exampleframeworkResponseFileService);
                
                // Process records using two-phase processor (EXAMPLE_FRAMEWORK phase only for now)
                result = recordProcessor.processRecords(
                    records, null, config.getStopFilePath(),  // Pass null for batchreportingApiKey to do EXAMPLE_FRAMEWORK only
                    config.getNotificationLogIndicator(), todoFile,
                    successReport, config.getNotificationIntervalMillis(),
                    todoFilePrefix);
                
                // Update bookmark status
                bookmarkService.updateStatus(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED);
                
                // Initialize BATCHREPORTING after EXAMPLE_FRAMEWORK is complete and before BATCHREPORTING processing
                if (config.isEnableBatchReportingApi() && !startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_INITIALIZED)) {
                    LOGGER.info("EXAMPLE_FRAMEWORK processing complete, initializing BATCHREPORTING for Phase 2");
                    batchreportingApiKey = batchreportingAdapter.beginFileProcessing(
                        Integer.parseInt(config.getBatchReportingApiAppId()), 
                        batchId,
                        config.getBatchReportingApiOutputDirectory());
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_INITIALIZED);
                    LOGGER.info("BATCHREPORTING initialized with batch ID: {}", batchId);
                    
                    // Now process BATCHREPORTING phase
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_PROCESSING);
                    recordProcessor.setBookmarkTracking(bookmarkService, 0); // BATCHREPORTING starts from beginning
                    recordProcessor.processBatchReportingPhaseOnly(
                        todoFile, todoFilePrefix, batchreportingApiKey);
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_COMPLETED);
                }
            } else {
                LOGGER.info("Skipping EXAMPLE_FRAMEWORK processing - already completed");
                // Need to reconstruct result from bookmark/files
                result = reconstructProcessingResult(existingBookmark.get());
            }
            
            // PHASE 2: BATCHREPORTING Processing (only for recovery when EXAMPLE_FRAMEWORK is complete but BATCHREPORTING isn't)
            if (config.isEnableBatchReportingApi() && 
                startingState.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED) &&
                !startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_COMPLETED)) {
                
                LOGGER.info("EXAMPLE_FRAMEWORK phase complete, processing BATCHREPORTING phase only (recovery scenario)");
                
                // Initialize BATCHREPORTING if not already done
                if (!startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_INITIALIZED)) {
                    batchreportingApiKey = batchreportingAdapter.beginFileProcessing(
                        Integer.parseInt(config.getBatchReportingApiAppId()), 
                        batchId,
                        config.getBatchReportingApiOutputDirectory());
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_INITIALIZED);
                    LOGGER.info("BATCHREPORTING initialized for recovery with batch ID: {}", batchId);
                }
                
                // Update status to BATCHREPORTING_PROCESSING
                if (!startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_PROCESSING)) {
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_PROCESSING);
                }
                
                // Determine starting position for BATCHREPORTING recovery
                int batchreportingStartLine = 0;
                if (startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_PROCESSING) && existingBookmark.isPresent()) {
                    batchreportingStartLine = existingBookmark.get().getLastCompletedLine();
                    LOGGER.info("Resuming BATCHREPORTING processing from line {}", batchreportingStartLine);
                }
                
                // Process saved EXAMPLE_FRAMEWORK responses through BATCHREPORTING
                recordProcessor.setExampleFrameworkResponseFileService(exampleframeworkResponseFileService);
                recordProcessor.setBookmarkTracking(bookmarkService, batchreportingStartLine);
                recordProcessor.processBatchReportingPhaseOnly(
                    todoFile, todoFilePrefix, batchreportingApiKey);
                
                // Update bookmark status
                bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_COMPLETED);
            }
            
            // Generate output files
            if (!startingState.isAtOrAfter(ProcessingState.OUTPUT_FILES_GENERATED)) {
                String timestamp = timeProvider.formatCurrentDate("yyyyMMddHHmmss");
                String comFileName = String.format("todoapp-%s%s-com-%s.txt", 
                    todoFilePrefix, todoFile, timestamp);
                String errFileName = String.format("todoapp-%s%s-err-%s.txt", 
                    todoFilePrefix, todoFile, timestamp);
                
                // Set job end time before writing COM report
                successReport.setJobEndTime(timeProvider.getCurrentLocalDateTime());
                
                // Write output files locally first
                fileOps.writeOutputFiles(config.getOutputDir(), comFileName, errFileName, 
                    successReport.toString(), result.getErrorRecords());
                
                bookmarkService.updateStatus(ProcessingState.OUTPUT_FILES_GENERATED);
                LOGGER.info("Output files generated: {} and {}", comFileName, errFileName);
            } else {
                LOGGER.info("Skipping output file generation - already completed");
            }
            
            // Transfer files to remote output archive directory
            if (!startingState.isAtOrAfter(ProcessingState.OUTPUT_FILES_TRANSFERRED)) {
                // Find the output files
                String filePrefix = String.format("todoapp-%s%s", todoFilePrefix, todoFile);
                File[] outputFiles = new File(config.getOutputDir()).listFiles(
                    (dir, name) -> name.startsWith(filePrefix));
                
                if (outputFiles != null && outputFiles.length >= 2) {
                    String comFileName = null;
                    String errFileName = null;
                    for (File f : outputFiles) {
                        if (f.getName().contains("-com-")) comFileName = f.getName();
                        if (f.getName().contains("-err-")) errFileName = f.getName();
                    }
                    
                    if (comFileName != null && errFileName != null) {
                        fileOps.transferOutputFiles(sftpService, sftpConnection, 
                            config.getOutputDir(), outputArchiveDir, comFileName, errFileName);
                        bookmarkService.updateStatus(ProcessingState.OUTPUT_FILES_TRANSFERRED);
                        LOGGER.info("Output files transferred to remote");
                    }
                }
            } else {
                LOGGER.info("Skipping output file transfer - already completed");
            }
            
            LOGGER.info("Processing complete. Success: {}, Errors: {}", 
                result.getSuccessCount(), result.getErrorCount());
            
            // Delete input file
            if (!startingState.isAtOrAfter(ProcessingState.INPUT_FILE_DELETED)) {
                try {
                    fileOps.deleteInputFile(inputFile);
                    bookmarkService.updateStatus(ProcessingState.INPUT_FILE_DELETED);
                    LOGGER.info("Deleted input file: {}", inputFile.getName());
                } catch (IOException e) {
                    LOGGER.error("Failed to delete input file: " + inputFile.getAbsolutePath(), e);
                    // Continue processing - deletion failure shouldn't stop the application
                }
            } else {
                LOGGER.info("Skipping input file deletion - already completed");
            }
            
        } finally {
            // Clean up BATCHREPORTING
            if (batchreportingApiKey != null) {
                try {
                    batchreportingAdapter.endFileProcessing(batchreportingApiKey);
                } catch (Exception e) {
                    LOGGER.error("Error ending BATCHREPORTING file processing", e);
                }
            }
            
            // Transfer BATCHREPORTING files if needed
            if (config.isEnableBatchReportingApi() && 
                !startingState.isAtOrAfter(ProcessingState.BATCHREPORTING_FILES_TRANSFERRED) &&
                fileOps.batchreportingOutputDirectoryExists(config.getBatchReportingApiOutputDirectory())) {
                try {
                    fileOps.sftpBatchReportingFiles(sftpService, sftpConnection, 
                        config.getBatchReportingApiOutputDirectory(), 
                        config.getRemoteBatchReportingOutputDirectory());
                    bookmarkService.updateStatus(ProcessingState.BATCHREPORTING_FILES_TRANSFERRED);
                    LOGGER.info("BATCHREPORTING files transferred");
                } catch (Exception e) {
                    LOGGER.error("Error transferring BATCHREPORTING files", e);
                }
            }
            
            // All done - cleanup temporary files and bookmark
            try {
                // Delete EXAMPLE_FRAMEWORK response file
                exampleframeworkResponseFileService.deleteExampleFrameworkResponseFile(todoFile, todoFilePrefix);
            } catch (Exception e) {
                LOGGER.warn("Failed to delete EXAMPLE_FRAMEWORK response file", e);
            }
            
            // Mark as completed before deleting
            bookmarkService.updateStatus(ProcessingState.COMPLETED);
            
            // Delete bookmark
            bookmarkService.deleteBookmark();
            LOGGER.info("Processing completed successfully, bookmark deleted");
        }
    }
    
    /**
     * Generate next submission ID for the given type.
     */
    private String generateTodoFile(String type) {
        try {
            return serviceProvider.getTodoFileService(type).getNextTodoFile();
        } catch (TodoFileServiceException e) {
            LOGGER.error("Failed to generate submission ID for type: " + type, e);
            throw new RuntimeException("Failed to generate submission ID for type: " + type, e);
        }
    }
    
    /**
     * Check if processing should stop.
     */
    private boolean shouldStop() {
        return fileSystemProvider.fileExists(config.getStopFilePath());
    }
    
    /**
     * Reconstruct processing result from bookmark/files for recovery.
     */
    private RecordProcessor.ProcessingResult reconstructProcessingResult(BookmarkService.BookmarkState bookmark) {
        // For recovery, we need to estimate success/error counts
        // This is a best effort - extype1 counts may not be recoverable
        int totalProcessed = bookmark.getLastCompletedLine();
        
        // Check for error file to count errors
        String todoFilePrefix = bookmark.getProcessType().equals("TYPE1") ? 
            Constants.TYPE1_TODO_FILE_PREFIX : Constants.TYPE2_TODO_FILE_PREFIX;
        String filePrefix = String.format("todoapp-%s%s", 
            todoFilePrefix, bookmark.getTodoFile());
        
        int errorCount = 0;
        File outputDir = new File(config.getOutputDir());
        if (outputDir.exists()) {
            File[] errFiles = outputDir.listFiles(
                (dir, name) -> name.startsWith(filePrefix) && name.contains("-err-"));
            if (errFiles != null && errFiles.length > 0) {
                // Try to count lines in error file
                try {
                    List<String> errorLines = fileService.readLines(errFiles[0]);
                    errorCount = errorLines.size();
                } catch (IOException e) {
                    LOGGER.warn("Could not count error records during recovery", e);
                }
            }
        }
        
        int successCount = totalProcessed - errorCount;
        LOGGER.info("Reconstructed result - Success: {}, Errors: {} (estimated)", 
            successCount, errorCount);
        
        return new RecordProcessor.ProcessingResult(new ArrayList<>(), new ArrayList<>(), 
            successCount, errorCount);
    }
