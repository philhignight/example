                validation.getPrcId(), validation.getAltPrcId());
            errorHandler.addErrorToComReport(successReport, errorCode, validation.getDescription());
        }
        
        // Update EXAMPLE_FRAMEWORK errors
        for (ExampleFrameworkPhaseProcessor.ExampleFrameworkError error : exampleframeworkResult.getExampleFrameworkErrors()) {
            ExampleFrameworkResponseData response = error.getResponseData();
            String errorCode = recordFormatter.formatComReportErrorCode(
                response.getReturnStatusCode(), response.getReturnReasonCode());
            errorHandler.addErrorToComReport(successReport, errorCode, response.getErrorMessage());
