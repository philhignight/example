    private int transtype1ionsProcessed = 0;
    private int transtype1ionsRejected = 0;
    private int transtype1ionsAccepted = 0;
    private long totalTxnProcessingTime = 0;
    
    // Error tracking
    private Map<String, Integer> errorCounts = new HashMap<>();
    private Map<String, String> errorDescriptions = new HashMap<>();
    private Map<String, Integer> nonCriticalCounts = new HashMap<>();
    private Map<String, String> nonCriticalDescriptions = new HashMap<>();
    
    private static final DateTimeFormatter DATE_FORMATTER = 
            DateTimeFormatter.ofPattern("MMM d, yyyy h:mm:ss a");
    
    public BatchJobReport(String jobName, String instance, String batchId,
            String runId, String siteId, String fileName, String restartInfo) {
        this.startTime = LocalDateTime.now();
        this.jobName = jobName;
        this.instance = instance;
        this.batchId = batchId;
        this.runId = runId;
        this.siteId = siteId;
        this.fileName = fileName;
        this.restartInfo = restartInfo;
    }
    
    public void setJobEndTime(LocalDateTime jobEndTime) {
        this.jobEndTime = jobEndTime;
    }
    
    public void acceptTranstype1ion() {
        transtype1ionsAccepted++;
    }
    
    public void skipTranstype1ion() {
        transtype1ionsSkipped++;
    }
    
