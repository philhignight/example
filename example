        this.fileSystemProvider = fileSystemProvider;
        this.threadProvider = threadProvider;
        
        String exampleframeworkUrl = exampleframeworkProtocol + "://" + exampleframeworkHost + ":" + exampleframeworkPort + exampleframeworkPath;
        HttpXmlGzipExampleFrameworkRouter exampleframeworkRouter = new HttpXmlGzipExampleFrameworkRouter(exampleframeworkUrl, (int) exampleframeworkRequestWaitTimeoutMillis);
        this.exampleframeworkClient = new ExampleFrameworkClient<ExchangeMessage>(exampleframeworkRouter, exampleframeworkTransientRetries, delayBetweenTransientExceptionRetryMillis,
                ExchangeMessage.class);
        LOGGER.info("EXAMPLE_FRAMEWORK client initialized with {} transient retries, {} ms delay between retries", 
            exampleframeworkTransientRetries, delayBetweenTransientExceptionRetryMillis);
    }

    /**
     * Sends an TODO update request to EXAMPLE_FRAMEWORK.
     * 
     * @param record TODO update record
     * @param stopFilePath path to stop file
     * @return EXAMPLE_FRAMEWORK response
     * @throws IOException        if an I/O error occurs
     * @throws StopException      if stop file detected
