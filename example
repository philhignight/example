public class AuditService {

    private static final Logger LOGGER = LogManager.getLogger(AuditService.class);
    private static final String PROP_APP_NAME = "appName";
    private static final String PROP_MYORG_REGION = "myorgRegion";
    
    private final SystemPropertyProvider propertyProvider;
    private final PackageInfoProvider packageInfoProvider;
    
    /**
     * Constructs a new AuditService with default providers.
     */
    public AuditService() {
        this(new SystemPropertyProvider(), new PackageInfoProvider());
    }
    
    /**
     * Constructs a new AuditService with custom providers.
     */
    public AuditService(SystemPropertyProvider propertyProvider, PackageInfoProvider packageInfoProvider) {
        this.propertyProvider = propertyProvider;
        this.packageInfoProvider = packageInfoProvider;
    }

    public void auditApplicationStart() {
        LOGGER.debug("sending audit for application start to logmonitor audit service");
        final String applicationName = propertyProvider.getProperty(PROP_APP_NAME);
        final String myorgRegion = propertyProvider.getProperty(PROP_MYORG_REGION);
        final Event event = createEvent(EventType.APPLICATION_START);

        event.addAttribute("appVersion", packageInfoProvider.getImplementationVersion(getClass()));
        event.addAttribute("appName", applicationName);
        event.addAttribute("deviceExternalId", myorgRegion);
        event.log();
