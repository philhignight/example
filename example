            if (batchreportingApiKey != null) {
                try {
                    LOGGER.debug("Calling BATCHREPORTING endFileProcessing()");
                    long startTime = System.currentTimeMillis();
                    batchreportingAdapter.endFileProcessing(batchreportingApiKey);
