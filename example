            this.validationResult = validationResult;
        }
        
        public TodoUpdateRecord getRecord() { return record; }
        public RecordValidator.ValidationResult getValidationResult() { return validationResult; }
    }
    
    /**
     * Represents a EXAMPLE_FRAMEWORK processing error.
     */
    public static class ExampleFrameworkError {
        private final TodoUpdateRecord record;
        private final ExampleFrameworkResponseData responseData;
        
        public ExampleFrameworkError(TodoUpdateRecord record, ExampleFrameworkResponseData responseData) {
            this.record = record;
            this.responseData = responseData;
