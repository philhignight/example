                        Constants.BatchReportingCounters.NewUserIdentifierTypeIsInvalid.PRC_CNTR_LBL_TX);
            }
        }

        // Create keys for this record (null-safe string concatenation)
        String currentOldIdKey = (record.getOldAdminstrId() != null ? record.getOldAdminstrId() : "") + ":" + 
                (record.getOldAdminstrIdType() != null ? record.getOldAdminstrIdType() : "");
        String currentNewIdKey = (record.getNewAdminstrId() != null ? record.getNewAdminstrId() : "") + ":" + 
                (record.getNewAdminstrIdType() != null ? record.getNewAdminstrIdType() : "");

        // Process each already processed record to check for duplicates, supersedes,
        // and reversals
        for (TodoUpdateRecord processedRecord : processedRecords) {
            String processedOldIdKey = (processedRecord.getOldAdminstrId() != null ? processedRecord.getOldAdminstrId() : "") + ":" + 
                    (processedRecord.getOldAdminstrIdType() != null ? processedRecord.getOldAdminstrIdType() : "");
            String processedNewIdKey = (processedRecord.getNewAdminstrId() != null ? processedRecord.getNewAdminstrId() : "") + ":" + 
