     * @throws StopException      if stop file detected
     */
    public ExchangeMessage sendTodoUpdateRequest(TodoUpdateRecord record, String stopFilePath) 
            throws IOException, StopException {
        // Generate EXAMPLE_FRAMEWORK instruction XML
        String instructionXml = generateExampleFrameworkInstructionXml(record);
        // Send to EXAMPLE_FRAMEWORK with record-level retries for transient errors
        return sendToExampleFrameworkWithRecordLevelRetries(instructionXml, stopFilePath);
    }

    /**
     * Generates EXAMPLE_FRAMEWORK instruction XML for an TODO update request.
     * 
     * @param record TODO update record
     * @return EXAMPLE_FRAMEWORK instruction XML
     */
    private String generateExampleFrameworkInstructionXml(TodoUpdateRecord record) {
        StringBuilder xml = new StringBuilder();
        xml.append("<?xml version=\"1.0\" encoding=\"UTF-8\" standalone=\"yes\"?>\n");
        xml.append("<ExchangeMessage>\n");
        xml.append("  <headers>\n");
        xml.append("    <Security productId=\"" + Constants.EXAMPLE_FRAMEWORK_PRODUCT_ID
                + "\" runId=\"0\" siteId=\"0\" userId=\"0\"/>\n");
        xml.append("  </headers>\n");
        xml.append("  <hints>\n");
        xml.append("    <Hint exampleframeworkSource=\"U\" instructionTypeCode=\"push\" pullType=\"family\"/>\n");
        xml.append("  </hints>\n");
        xml.append("  <inputs>\n");
        xml.append("    <AdminstrBUSINESSOBJECT subjectUpdateCode=\"N\">\n");
        xml.append("      <PersonIdentityBUSINESSOBJECT\n");
        xml.append("        personId=\"" + (record.getOldAdminstrId() != null ? record.getOldAdminstrId() : "") + "\"\n");
        xml.append("        personIdTypeCode=\"" + (record.getOldAdminstrIdType() != null ? record.getOldAdminstrIdType() : "") + "\"\n");
        xml.append("        personLastName=\"" + (record.getLastName() != null ? record.getLastName() : "") + "\"\n");
        xml.append("      />\n");
        xml.append("      <IdentityChangeBUSINESSOBJECT\n");
        xml.append("        personId=\"" + (record.getNewAdminstrId() != null ? record.getNewAdminstrId() : "") + "\"\n");
        xml.append("        personIdTypeCode=\"" + (record.getNewAdminstrIdType() != null ? record.getNewAdminstrIdType() : "") + "\"\n");
        xml.append("        subjectUpdateCode=\"M\"\n");
        xml.append("      />\n");
        xml.append("    </AdminstrBUSINESSOBJECT>\n");
        xml.append("  </inputs>\n");
        xml.append("</ExchangeMessage>");
        return xml.toString();
    }

    /**
     * Sends a request to EXAMPLE_FRAMEWORK with record-level retries for transient errors.
     * 
     * @param instructionXml EXAMPLE_FRAMEWORK instruction XML
     * @param stopFilePath Path to stop file
     * @return EXAMPLE_FRAMEWORK response
     * @throws IOException   if an I/O error occurs
     * @throws StopException if stop file is detected
     */
    private ExchangeMessage sendToExampleFrameworkWithRecordLevelRetries(String instructionXml, String stopFilePath) 
            throws IOException, StopException {
        int recordRetryAttempts = 0;
        long startTime = timeProvider.currentTimeMillis();
        long lastNotificationTime = 0;

        while (true) {
            recordRetryAttempts++;
            
            try {
                // Use processInstructionWithRetries which handles EXAMPLE_FRAMEWORK-level retries internally
                LOGGER.debug("Sending EXAMPLE_FRAMEWORK request, record retry attempt: {}", recordRetryAttempts);
                ExchangeMessage response = this.exampleframeworkClient.processInstructionWithRetries(instructionXml);
                
                // Success - return the response
                if (recordRetryAttempts > 1) {
                    LOGGER.info("EXAMPLE_FRAMEWORK request succeeded after {} record-level retry attempts", recordRetryAttempts);
                }
                return response;
                
            } catch (TransientStatusDetailException e) {
                // EXAMPLE_FRAMEWORK client exhausted its retries but still getting transient errors
                LOGGER.warn("EXAMPLE_FRAMEWORK client exhausted retries with transient error. Starting record-level retry {} in {} ms", 
                    recordRetryAttempts, delayBetweenTransientExceptionRetryMillis);
                
                // Check for STOP file
                if (fileSystemProvider.fileExists(stopFilePath)) {
                    LOGGER.info("Abandoning retries because stop file exists: {}", stopFilePath);
                    throw new StopException();
                }
                
                // Check if we've been retrying for notification interval and need to send notification
                long currentTime = timeProvider.currentTimeMillis();
                long elapsedTime = currentTime - startTime;
                
                if (elapsedTime >= notificationIntervalMillis
                        && (currentTime - lastNotificationTime >= notificationIntervalMillis
                                || lastNotificationTime == 0)) {
                    // Send notification email by logging
                    LOGGER.error("EXAMPLE_FRAMEWORK push failed. Retrying at record level. {}", notificationLogIndicator);
                    lastNotificationTime = currentTime;
                }
                
                // Wait before next record-level retry
                try {
                    threadProvider.sleep(delayBetweenTransientExceptionRetryMillis);
                } catch (InterruptedException ie) {
                    Thread.currentThread().interrupt();
                    throw new IOException("Record-level retry interrupted", ie);
                }
                
            } catch (StatusDetailException e) {
                // Non-transient error - return the error response
                LOGGER.error("EXAMPLE_FRAMEWORK push failed with non-transient error after {} record retry attempts", 
                    recordRetryAttempts);
                return (ExchangeMessage) e.getResponse();
            }
        }
    }

