     * using reference equality (==)
     * 
     * @param record           The record to remove
     * @param processedRecords The original list of records
     * @return A new list with the specified record removed
     */
    private List<TodoUpdateRecord> copyAndRemoveRecord(TodoUpdateRecord record, List<TodoUpdateRecord> processedRecords) {
        // Create a copy of the original list
        List<TodoUpdateRecord> recordsCopy = new ArrayList<>(processedRecords);
        // Find the index of the record by reference
        for (int i = 0; i < recordsCopy.size(); i++) {
            if (recordsCopy.get(i) == record) { // Using == for reference equality
                recordsCopy.remove(i);
                break;
            }
        }
        return recordsCopy;
    }

    private boolean isNumeric(String str) {
        if (str == null) {
            return false;
        }
        return str.matches("\\d+");
    }

    private boolean isValidDate(String dateStr) {
        try {
            DateTimeFormatter formatter = DateTimeFormatter.ofPattern("yyyyMMdd");
            LocalDate.parse(dateStr, formatter);
            return true;
        } catch (DateTimeParseException e) {
            return false;
        }
    }

    private boolean isValidIdTypeTransition(String oldType, String newType) {
        switch (oldType) {
            case "S":
                return ALLOWED_S_TRANSITIONS.contains(newType);
            case "P":
                return ALLOWED_P_TRANSITIONS.contains(newType);
            case "I":
                return ALLOWED_I_TRANSITIONS.contains(newType);
            case "T":
                return ALLOWED_T_TRANSITIONS.contains(newType);
            case "N":
                return ALLOWED_N_TRANSITIONS.contains(newType);
            case "D":
                return ALLOWED_D_TRANSITIONS.contains(newType);
            case "F":
                return ALLOWED_F_TRANSITIONS.contains(newType);
            case "R":
