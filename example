    @Test
    void testDuplicateTranstype1ionDetection() {
        List<TodoUpdateRecord> processedRecords = new ArrayList<>();
        
        // First record: A -> B
        TodoUpdateRecord record1 = createRecord("111111111", "S", "222222222", "S");
        assertNull(validator.validateRecord(record1, processedRecords));
        processedRecords.add(record1);
        
        // Second record: A -> B again (duplicate)
        TodoUpdateRecord record2 = createRecord("111111111", "S", "222222222", "S");
        RecordValidator.ValidationResult result = validator.validateRecord(record2, processedRecords);
        
        assertNotNull(result);
        assertEquals("302", result.getAltPrcId());
        assertEquals("36", result.getOldReturnCode());
        assertEquals("TRANSTYPE1ION DUPLICATED BY A LATER ONE.", result.getDescription());
    }
    
