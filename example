package com.example.todoapp.processor;

import java.io.IOException;
import java.util.ArrayList;
import java.util.List;

import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import com.example.deers.batchreporting.api.BatchReportingApiKey;
import com.example.todoapp.Constants;
import com.example.todoapp.batchreporting.BatchReportingAdapter;
import com.example.todoapp.model.ExampleFrameworkResponseData;
import com.example.todoapp.model.TodoUpdateRecord;
import com.example.todoapp.model.jsonl.JsonlProcessorType1ion;
import com.example.todoapp.provider.IdGenerator;
import com.example.todoapp.service.BookmarkService;
import com.example.todoapp.service.ExampleFrameworkResponseFileService;
import com.example.todoapp.util.Utils;
import myorg.mybatchscheduler.lib.exampleframeworkinstruction.IFrameworkStatus;

/**
 * Handles the BATCHREPORTING phase of record processing.
 * Responsible for reading EXAMPLE_FRAMEWORK responses and updating BATCHREPORTING.
 */
public class BatchReportingPhaseProcessor {
    
    private static final Logger LOGGER = LogManager.getLogger(BatchReportingPhaseProcessor.class);
    
    private final BatchReportingAdapter batchreportingAdapter;
    private ExampleFrameworkResponseFileService responseFileService;
    private final IdGenerator idGenerator;
    
    public BatchReportingPhaseProcessor(BatchReportingAdapter batchreportingAdapter,
                              ExampleFrameworkResponseFileService responseFileService,
                              IdGenerator idGenerator) {
        this.batchreportingAdapter = batchreportingAdapter;
        this.responseFileService = responseFileService;
        this.idGenerator = idGenerator;
    }
    
    /**
     * Set the EXAMPLE_FRAMEWORK response file service.
     */
    public void setExampleFrameworkResponseFileService(ExampleFrameworkResponseFileService responseFileService) {
        this.responseFileService = responseFileService;
    }
    
    /**
     * Result of BATCHREPORTING phase processing.
     */
    public static class BatchReportingPhaseResult {
        private final int recordsProcessed;
        private final int batchreportingUpdatesCompleted;
        
        public BatchReportingPhaseResult(int recordsProcessed, int batchreportingUpdatesCompleted) {
            this.recordsProcessed = recordsProcessed;
            this.batchreportingUpdatesCompleted = batchreportingUpdatesCompleted;
        }
        
        public int getRecordsProcessed() { return recordsProcessed; }
        public int getBatchReportingUpdatesCompleted() { return batchreportingUpdatesCompleted; }
    }
    
    /**
     * Process BATCHREPORTING phase by reading EXAMPLE_FRAMEWORK responses and updating BATCHREPORTING.
     */
    public BatchReportingPhaseResult processBatchReportingPhase(String todoFile,
                                             String todoFilePrefix,
                                             BatchReportingApiKey batchreportingApiKey,
                                             BookmarkService bookmarkService,
                                             int startingLine) throws IOException {
        
        // Validate parameters are not null
        if (todoFile == null) {
            throw new IllegalArgumentException("todoFile cannot be null");
        }
        if (todoFilePrefix == null) {
            throw new IllegalArgumentException("todoFilePrefix cannot be null");
        }
        if (batchreportingApiKey == null) {
            throw new IllegalArgumentException("batchreportingApiKey cannot be null");
        }
        
        LOGGER.info("Starting BATCHREPORTING phase processing from line {}", startingLine);
        
        // Read all EXAMPLE_FRAMEWORK responses
        List<ExampleFrameworkResponseData> responses = responseFileService.readAllExampleFrameworkResponses(
            todoFile, todoFilePrefix);
        
        int recordsProcessed = 0;
        int batchreportingUpdatesCompleted = 0;
        
        // Skip to starting line if recovering
        int startIndex = Math.max(0, startingLine);
        
        for (int i = startIndex; i < responses.size(); i++) {
            ExampleFrameworkResponseData responseData = responses.get(i);
            recordsProcessed++;
            
            try {
                updateBatchReportingForRecord(responseData, batchreportingApiKey, todoFile, todoFilePrefix);
                batchreportingUpdatesCompleted++;
                
                // Update bookmark progress
                if (bookmarkService != null) {
                    try {
                        bookmarkService.updateProgress(i + 1);
                    } catch (IOException e) {
                        LOGGER.warn("Failed to update bookmark progress", e);
                    }
                }
                
            } catch (Exception e) {
                LOGGER.error("Error updating BATCHREPORTING for record at line {}", 
                    responseData.getLineNumber(), e);
                // Continue processing other records
            }
        }
        
        LOGGER.info("BATCHREPORTING phase completed. Processed: {}, Updated: {}", 
            recordsProcessed, batchreportingUpdatesCompleted);
        
        return new BatchReportingPhaseResult(recordsProcessed, batchreportingUpdatesCompleted);
    }
    
    /**
