    @Test
    void testIsAfter() {
        assertTrue(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isAfter(ProcessingState.NOT_STARTED));
        assertTrue(ProcessingState.BATCHREPORTING_COMPLETED.isAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertTrue(ProcessingState.COMPLETED.isAfter(ProcessingState.BATCHREPORTING_COMPLETED));
        
        assertFalse(ProcessingState.NOT_STARTED.isAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertFalse(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertFalse(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isAfter(ProcessingState.BATCHREPORTING_COMPLETED));
    }
    
    @Test
    void testIsBefore() {
        assertTrue(ProcessingState.NOT_STARTED.isBefore(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertTrue(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isBefore(ProcessingState.BATCHREPORTING_COMPLETED));
        assertTrue(ProcessingState.BATCHREPORTING_COMPLETED.isBefore(ProcessingState.COMPLETED));
        
        assertFalse(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isBefore(ProcessingState.NOT_STARTED));
        assertFalse(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isBefore(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertFalse(ProcessingState.BATCHREPORTING_COMPLETED.isBefore(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
    }
    
    @Test
    void testIsAtOrAfter() {
        assertTrue(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isAtOrAfter(ProcessingState.NOT_STARTED));
        assertTrue(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertTrue(ProcessingState.BATCHREPORTING_COMPLETED.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        
        assertFalse(ProcessingState.NOT_STARTED.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
        assertFalse(ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING.isAtOrAfter(ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED));
    }
    
    @Test
    void testOrdinalProgression() {
        // Verify that ordinals increase in the expected order
        ProcessingState[] states = ProcessingState.values();
        for (int i = 0; i < states.length - 1; i++) {
            assertTrue(states[i].ordinal() < states[i + 1].ordinal());
            assertTrue(states[i].isBefore(states[i + 1]));
            assertTrue(states[i + 1].isAfter(states[i]));
        }
    }
    
    @Test
