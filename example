import java.util.Optional;
import java.util.stream.Collectors;
import java.util.Date;
import java.util.stream.Stream;

import org.apache.logging.log4j.LogManager;
import org.apache.logging.log4j.Logger;

import com.example.todoapp.Constants;
import com.example.todoapp.config.TodoUpdBatchConfiguration;
import com.example.todoapp.processor.ProcessingState;
import com.example.todoapp.provider.FileSystemProvider;

/**
 * Service for determining the current processing state and recovery context.
 * Analyzes the file system and bookmark to determine where to resume processing.
 */
public class RecoveryService {
    
    private static final Logger LOGGER = LogManager.getLogger(RecoveryService.class);
    
    private final BookmarkService bookmarkService;
    private final TodoUpdBatchConfiguration config;
    private final FileSystemProvider fileSystemProvider;
    
    public RecoveryService(BookmarkService bookmarkService,
                          TodoUpdBatchConfiguration config,
                          FileSystemProvider fileSystemProvider) {
        this.bookmarkService = bookmarkService;
        this.config = config;
        this.fileSystemProvider = fileSystemProvider;
    }
    
    /**
     * Recovery context containing all information needed to resume processing.
     */
    public static class RecoveryContext {
        private final ProcessingState startState;
        private final ProcessingState targetState;
        private final BookmarkService.BookmarkState bookmark;
        private final File inputFile;
        private final boolean isRecovery;
        
        public RecoveryContext(ProcessingState startState, 
                             ProcessingState targetState,
                             BookmarkService.BookmarkState bookmark,
                             File inputFile,
                             boolean isRecovery) {
            this.startState = startState;
            this.targetState = targetState;
            this.bookmark = bookmark;
            this.inputFile = inputFile;
            this.isRecovery = isRecovery;
        }
        
        public ProcessingState getStartState() { return startState; }
        public ProcessingState getTargetState() { return targetState; }
        public BookmarkService.BookmarkState getBookmark() { return bookmark; }
        public File getInputFile() { return inputFile; }
        public boolean isRecovery() { return isRecovery; }
        
        /**
         * Check if a given operation should be skipped based on current state.
         */
        public boolean shouldSkip(ProcessingState operationState) {
            // If we're starting at or after this operation, skip it
            return startState.isAtOrAfter(operationState);
        }
    }
    
    /**
     * Determine the recovery context for a specific process type.
     * Returns empty if no recovery is needed (fresh start).
     */
    public Optional<RecoveryContext> determineRecoveryContext(String processType) {
        LOGGER.debug("Determining recovery context for process type: {}", processType);
        
        // Check for bookmark first
        Optional<BookmarkService.BookmarkState> bookmarkOpt = bookmarkService.loadBookmark();
        
        if (!bookmarkOpt.isPresent()) {
            LOGGER.debug("No bookmark found, checking for orphaned files");
            return checkForOrphanedFiles(processType);
        }
        
        BookmarkService.BookmarkState bookmark = bookmarkOpt.get();
        
        // Check if bookmark is for the requested process type
        if (!processType.equals(bookmark.getProcessType())) {
            LOGGER.warn("Bookmark exists for different process type: {} (requested: {})", 
                bookmark.getProcessType(), processType);
            return Optional.empty();
        }
        
        LOGGER.info("Found bookmark for recovery - submission: {}, status: {}", 
            bookmark.getTodoFile(), bookmark.getStatus());
        return analyzeBookmarkState(bookmark);
    }
    
    /**
     * Analyze bookmark state to determine recovery context.
     */
    private Optional<RecoveryContext> analyzeBookmarkState(BookmarkService.BookmarkState bookmark) {
        LOGGER.debug("Analyzing bookmark state - status: {}, line: {}/{}", 
            bookmark.getStatus(), bookmark.getLastCompletedLine(), bookmark.getTotalLines());
            
        ProcessingState currentState;
        File inputFile = new File(bookmark.getInputFile());
        
        if (!inputFile.exists()) {
            LOGGER.warn("Input file from bookmark no longer exists: {}", inputFile.getAbsolutePath());
        }
        
        // Determine current state based on bookmark status and file system
        switch (bookmark.getStatus()) {
            case "NOT_STARTED":
                currentState = ProcessingState.NOT_STARTED;
                break;
                
            case "FILE_DOWNLOADED":
                currentState = ProcessingState.FILE_DOWNLOADED;
                break;
                
            case "TODO_FILE_GENERATED":
                currentState = ProcessingState.TODO_FILE_GENERATED;
                break;
                
            case "INPUT_FILE_ARCHIVED":
                currentState = ProcessingState.INPUT_FILE_ARCHIVED;
                break;
                
            case "EXAMPLE_FRAMEWORK_PROCESSING":
                currentState = ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING;
                break;
                
            case "EXAMPLE_FRAMEWORK_COMPLETED":
                currentState = ProcessingState.EXAMPLE_FRAMEWORK_COMPLETED;
                break;
                
            case "BATCHREPORTING_INITIALIZED":
                currentState = ProcessingState.BATCHREPORTING_INITIALIZED;
                break;
                
            case "BATCHREPORTING_PROCESSING":
                currentState = ProcessingState.BATCHREPORTING_PROCESSING;
                break;
                
            case "BATCHREPORTING_COMPLETED":
                currentState = ProcessingState.BATCHREPORTING_COMPLETED;
                break;
                
            case "OUTPUT_FILES_GENERATED":
            case "OUTPUT_GENERATED":  // Handle both variants
                currentState = ProcessingState.OUTPUT_FILES_GENERATED;
                break;
                
            case "OUTPUT_FILES_TRANSFERRED":
            case "OUTPUT_TRANSFERRED":  // Handle both variants
                currentState = ProcessingState.OUTPUT_FILES_TRANSFERRED;
                break;
                
            case "INPUT_FILE_DELETED":
                currentState = ProcessingState.INPUT_FILE_DELETED;
                break;
                
            case "BATCHREPORTING_FINALIZED":
                currentState = ProcessingState.BATCHREPORTING_FINALIZED;
                break;
                
            case "BATCHREPORTING_FILES_TRANSFERRED":
                currentState = ProcessingState.BATCHREPORTING_FILES_TRANSFERRED;
                break;
                
            case "COMPLETED":
                currentState = ProcessingState.COMPLETED;
                break;
                
            case "PROCESSING":
                // Legacy status from BookmarkService - determine type1ual state from file system
                currentState = determineStateFromFileSystem(bookmark);
                break;
                
            default:
                LOGGER.warn("Unknown bookmark status: '{}'. Attempting to determine state from file system.", 
                    bookmark.getStatus());
                currentState = determineStateFromFileSystem(bookmark);
        }
        
        LOGGER.info("Recovery context determined - submission: {}, starting from state: {}, progress: {}/{}", 
            bookmark.getTodoFile(), currentState, 
            bookmark.getLastCompletedLine(), bookmark.getTotalLines());
        
        // Target is always COMPLETED for recovery
        RecoveryContext context = new RecoveryContext(
            currentState,
            ProcessingState.COMPLETED,
            bookmark,
            inputFile,
            true
        );
        
        LOGGER.debug("Recovery will skip states before: {}", currentState);
        return Optional.of(context);
    }
    
    /**
     * Check for orphaned files when no bookmark exists.
     */
    private Optional<RecoveryContext> checkForOrphanedFiles(String processType) {
        LOGGER.debug("Checking for orphaned files in: {}", config.getLocalSftpDir());
        
        try {
            // Check for input files in local SFTP directory
            Path localPath = Paths.get(config.getLocalSftpDir());
            if (!Files.exists(localPath)) {
                LOGGER.debug("Local SFTP directory does not exist: {}", localPath);
                return Optional.empty();
            }
            
            // Look for TODO update input files
            try (Stream<Path> files = Files.list(localPath)) {
                List<File> inputFiles = files
                    .filter(path -> {
                        String name = path.getFileName().toString();
                        // Look for input files, excluding temporary and partial files
                        boolean isFile = Files.isRegularFile(path);
                        boolean notTemporary = !name.endsWith(".tmp") && 
                                              !name.endsWith(".partial") &&
                                              !name.startsWith(".");
                        boolean matches = isFile && notTemporary;
                        if (matches) {
                            LOGGER.debug("Found potential orphaned file: {}", name);
                        }
                        return matches;
                    })
                    .map(Path::toFile)
                    .sorted((a, b) -> Long.compare(a.lastModified(), b.lastModified()))
                    .collect(Collectors.toList());
                
                if (!inputFiles.isEmpty()) {
                    File orphanedFile = inputFiles.get(0);
                    LOGGER.warn("Found {} orphaned input file(s). Will process oldest: {} (modified: {})", 
                        inputFiles.size(), orphanedFile.getName(), new Date(orphanedFile.lastModified()));
                    
                    // No bookmark, so we start from the beginning with this file
                    return Optional.of(new RecoveryContext(
                        ProcessingState.FILE_DOWNLOADED,
                        ProcessingState.COMPLETED,
                        null,
                        orphanedFile,
                        true
                    ));
                } else {
                    LOGGER.debug("No orphaned files found");
                }
            }
        } catch (IOException e) {
            LOGGER.error("Error checking for orphaned files in: {}", config.getLocalSftpDir(), e);
        }
        
        return Optional.empty();
    }
    
    /**
     * Determine state from file system when bookmark status is ambiguous.
     */
    private ProcessingState determineStateFromFileSystem(BookmarkService.BookmarkState bookmark) {
        LOGGER.debug("Determining state from file system for submission: {}", bookmark.getTodoFile());
        
        String todoFilePrefix = bookmark.getProcessType().equals("TYPE1") ? 
            Constants.TYPE1_TODO_FILE_PREFIX : Constants.TYPE2_TODO_FILE_PREFIX;
        String filePrefix = String.format("todoapp-%s%s", 
            todoFilePrefix, bookmark.getTodoFile());
        
        // Check for output files
        File outputDir = new File(config.getOutputDir());
        if (outputDir.exists()) {
            File[] files = outputDir.listFiles((dir, name) -> name.startsWith(filePrefix));
            if (files != null && files.length > 0) {
                boolean hasComFile = false;
                boolean hasErrFile = false;
                
                for (File file : files) {
                    if (file.getName().contains("-com-")) {
                        hasComFile = true;
                        LOGGER.debug("Found COM file: {}", file.getName());
                    }
                    if (file.getName().contains("-err-")) {
                        hasErrFile = true;
                        LOGGER.debug("Found ERR file: {}", file.getName());
                    }
                }
                
                if (hasComFile && hasErrFile) {
                    LOGGER.info("Found output files, state is at least OUTPUT_FILES_GENERATED");
                    return ProcessingState.OUTPUT_FILES_GENERATED;
                }
            }
        }
        
        // Check if input file still exists
        File inputFile = new File(bookmark.getInputFile());
        if (!inputFile.exists()) {
            LOGGER.info("Input file no longer exists, state is at least INPUT_FILE_DELETED");
            return ProcessingState.INPUT_FILE_DELETED;
        }
        
        // Check for EXAMPLE_FRAMEWORK response file
        ExampleFrameworkResponseFileService exampleframeworkService = new ExampleFrameworkResponseFileService(config.getOutputDir());
        if (exampleframeworkService.exampleframeworkResponseFileExists(bookmark.getTodoFile(), todoFilePrefix)) {
            LOGGER.info("Found EXAMPLE_FRAMEWORK response file, checking if EXAMPLE_FRAMEWORK phase is complete");
            // Could check line count to see if all records processed
        }
        
        // Default to where we left off in processing
        if (bookmark.getLastCompletedLine() > 0) {
            LOGGER.debug("Records partially processed, resuming EXAMPLE_FRAMEWORK_PROCESSING");
            return ProcessingState.EXAMPLE_FRAMEWORK_PROCESSING;
        }
        
        LOGGER.debug("No progress found, starting from BATCHREPORTING_INITIALIZED");
        return ProcessingState.BATCHREPORTING_INITIALIZED;
    }
