package com.example.todoapp;

import java.io.BufferedReader;
import java.io.FileReader;
import java.io.IOException;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

/**
 * Validates ConfigMap and Values YAML files for TODO Update Batch configuration.
 * Parses YAML without external libraries and validates environment variable mappings.
 */
public class YamlConfigValidator {
    
    private static final int INDENT_SIZE = 2;
    
    public static void main(String[] args) {
        if (args.length != 2) {
            System.err.println("Usage: java YamlConfigValidator <configmap.yaml> <values.yaml>");
            System.exit(1);
        }
        
        String configMapFile = args[0];
        String valuesFile = args[1];
        
        try {
            // Parse both YAML files
            Map<String, Object> configMap = parseYaml(configMapFile);
            Map<String, Object> values = parseYaml(valuesFile);
            
            // Extrtype1 configMap.data
            Map<String, String> configMapData = extrtype1ConfigMapData(configMap);
            if (configMapData == null || configMapData.isEmpty()) {
                System.err.println("Error: configMap.data not found or empty");
                System.exit(1);
            }
            
            // Load configMap.data as system properties
            for (Map.Entry<String, String> entry : configMapData.entrySet()) {
                System.setProperty(entry.getKey(), entry.getValue());
                System.out.println("Loaded system property: " + entry.getKey() + "=" + entry.getValue());
            }
            
            // Extrtype1 values.env
            List<Map<String, Object>> valuesEnv = extrtype1ValuesEnv(values);
            if (valuesEnv == null || valuesEnv.isEmpty()) {
                System.err.println("Error: values.env not found or empty");
                System.exit(1);
            }
            
            // Build valueMap from values.env
            Map<String, String> valueMap = buildValueMap(valuesEnv);
            
            // Validate that keys match between configMap.data and valueMap
            validateKeyMatching(configMapData, valueMap);
            
            // Extrtype1 entrypoint command template
            String commandTemplate = extrtype1Entrypoint(values);
            if (commandTemplate == null || commandTemplate.isEmpty()) {
                System.err.println("Error: values.entrypoint not found or empty");
                System.exit(1);
            }
            
            // Process command template with substitutions
            String finalCommand = processCommandTemplate(commandTemplate, valuesEnv, configMapData);
            
            // Print final command
            System.out.println("\nFinal command:");
            System.out.println(finalCommand);
            
        } catch (Exception e) {
            System.err.println("Error processing files: " + e.getMessage());
            e.printStackTrace();
            System.exit(1);
        }
    }
    
    /**
     * Simple YAML parser that handles basic structures.
     */
    private static Map<String, Object> parseYaml(String filename) throws IOException {
        Map<String, Object> result = new HashMap<>();
        List<String> lines = new ArrayList<>();
        
        try (BufferedReader reader = new BufferedReader(new FileReader(filename))) {
            String line;
            while ((line = reader.readLine()) != null) {
                // Skip empty lines and comments
                if (!line.trim().isEmpty() && !line.trim().startsWith("#")) {
                    lines.add(line);
                }
            }
        }
        
        parseYamlLines(lines, 0, result, 0);
        return result;
    }
    
    /**
     * Recursively parse YAML lines into a map structure.
     */
    private static int parseYamlLines(List<String> lines, int startIndex, Map<String, Object> currentMap, int expectedIndent) {
        int i = startIndex;
        
        while (i < lines.size()) {
            String line = lines.get(i);
            int indent = getIndentLevel(line);
            
            // If indent is less than expected, we've reached the end of this level
            if (indent < expectedIndent) {
                return i;
            }
            
            // Skip lines that don't match expected indent
            if (indent > expectedIndent) {
                i++;
                continue;
            }
            
            String trimmed = line.trim();
            
            // Skip list items at this level - they're handled by parseYamlList
            if (trimmed.startsWith("- ")) {
                i++;
                continue;
            }
            
            // Handle key-value pairs
            if (trimmed.contains(":")) {
                String[] parts = trimmed.split(":", 2);
                String key = parts[0].trim();
                String value = parts.length > 1 ? parts[1].trim() : "";
                
                if (value.isEmpty()) {
                    // Check if next line is a list
                    if (i + 1 < lines.size()) {
                        String nextLine = lines.get(i + 1);
                        if (nextLine.trim().startsWith("- ")) {
                            // This is a list
                            List<Object> list = new ArrayList<>();
                            i = parseYamlList(lines, i + 1, list, indent + INDENT_SIZE);
                            currentMap.put(key, list);
                            continue;
                        }
                    }
                    // This is a nested object
                    Map<String, Object> nestedMap = new HashMap<>();
                    i = parseYamlLines(lines, i + 1, nestedMap, indent + INDENT_SIZE);
                    currentMap.put(key, nestedMap);
                    continue;
                } else {
                    // Simple key-value pair
                    // Remove quotes if present
                    if (value.startsWith("\"") && value.endsWith("\"")) {
                        value = value.substring(1, value.length() - 1);
                    } else if (value.startsWith("'") && value.endsWith("'")) {
                        value = value.substring(1, value.length() - 1);
                    }
                    currentMap.put(key, value);
                }
            }
            
            i++;
        }
        
        return i;
    }
    
    /**
     * Parse a YAML list structure.
     */
    private static int parseYamlList(List<String> lines, int startIndex, List<Object> list, int baseIndent) {
        int i = startIndex;
        
        while (i < lines.size()) {
            String line = lines.get(i);
            int indent = getIndentLevel(line);
            
            if (indent < baseIndent) {
                return i;
            }
            
            String trimmed = line.trim();
            if (trimmed.startsWith("- ")) {
                String content = trimmed.substring(2).trim();
                
                if (content.isEmpty()) {
                    // List item is a nested object
                    Map<String, Object> itemMap = new HashMap<>();
                    i = parseYamlLines(lines, i + 1, itemMap, baseIndent + INDENT_SIZE + 2);
                    list.add(itemMap);
                } else if (content.contains(":")) {
                    // List item starts with a key-value pair
                    Map<String, Object> itemMap = new HashMap<>();
                    String[] parts = content.split(":", 2);
                    String key = parts[0].trim();
                    String value = parts.length > 1 ? parts[1].trim() : "";
                    
                    if (value.isEmpty()) {
                        // Value is on next lines
                        itemMap.put(key, new HashMap<String, Object>());
                        i = parseYamlLines(lines, i + 1, (Map<String, Object>)itemMap.get(key), baseIndent + INDENT_SIZE + 2);
                    } else {
                        // Simple value
                        itemMap.put(key, value);
                        // Check for more properties of this list item
                        int nextLine = i + 1;
                        if (nextLine < lines.size()) {
                            int nextIndent = getIndentLevel(lines.get(nextLine));
                            if (nextIndent > baseIndent && !lines.get(nextLine).trim().startsWith("- ")) {
                                i = parseYamlLines(lines, nextLine, itemMap, baseIndent + INDENT_SIZE);
                            }
                        }
                    }
                    list.add(itemMap);
                } else {
                    // Simple string item
                    list.add(content);
                    i++;
                }
            } else {
                i++;
            }
        }
        
        return i;
    }
    
    /**
     * Get the indentation level of a line.
     */
    private static int getIndentLevel(String line) {
        int count = 0;
        for (char c : line.toCharArray()) {
            if (c == ' ') {
                count++;
            } else {
                break;
            }
        }
        return count;
    }
    
    /**
     * Extrtype1 configMap.data from parsed YAML.
     */
    @SuppressWarnings("unchecked")
    private static Map<String, String> extrtype1ConfigMapData(Map<String, Object> configMap) {
        Object dataObj = configMap.get("data");
        if (dataObj instanceof Map) {
            Map<String, Object> dataMap = (Map<String, Object>) dataObj;
            Map<String, String> result = new HashMap<>();
            for (Map.Entry<String, Object> entry : dataMap.entrySet()) {
                result.put(entry.getKey(), String.valueOf(entry.getValue()));
            }
            return result;
        }
        return null;
    }
    
    /**
     * Extrtype1 values.env from parsed YAML.
     */
    @SuppressWarnings("unchecked")
    private static List<Map<String, Object>> extrtype1ValuesEnv(Map<String, Object> values) {
        Object envObj = values.get("env");
        if (envObj instanceof List) {
            return (List<Map<String, Object>>) envObj;
        }
        return null;
    }
    
    /**
     * Build valueMap from values.env entries.
     */
    @SuppressWarnings("unchecked")
    private static Map<String, String> buildValueMap(List<Map<String, Object>> valuesEnv) {
        Map<String, String> valueMap = new HashMap<>();
        
        for (Map<String, Object> envEntry : valuesEnv) {
            String name = (String) envEntry.get("name");
            Map<String, Object> valueFrom = (Map<String, Object>) envEntry.get("valueFrom");
            
            if (name != null && valueFrom != null) {
                Map<String, Object> configMapKeyRef = (Map<String, Object>) valueFrom.get("configMapKeyRef");
                if (configMapKeyRef != null) {
                    String key = (String) configMapKeyRef.get("key");
                    if (key != null) {
                        valueMap.put(name, key);
                    }
                }
            }
        }
        
        return valueMap;
    }
    
    /**
     * Validate that keys match between configMap.data and valueMap.
     */
    private static void validateKeyMatching(Map<String, String> configMapData, Map<String, String> valueMap) {
        // Check if sizes match
        if (configMapData.size() != valueMap.size()) {
            System.err.println("Error: Key count mismatch!");
            System.err.println("configMap.data has " + configMapData.size() + " entries");
            System.err.println("values.env references " + valueMap.size() + " keys");
            System.err.println("\nconfigMap.data keys: " + configMapData.keySet());
            System.err.println("values.env referenced keys: " + valueMap.values());
            System.exit(1);
        }
        
        // Check if all valueMap values exist as keys in configMapData
        for (Map.Entry<String, String> entry : valueMap.entrySet()) {
            String envVarName = entry.getKey();
            String configMapKey = entry.getValue();
            
            if (!configMapData.containsKey(configMapKey)) {
                System.err.println("Error: values.env references key '" + configMapKey + 
                                 "' (for env var '" + envVarName + "') which doesn't exist in configMap.data");
                System.exit(1);
            }
        }
        
        // Check if all configMapData keys are referenced
        for (String configMapKey : configMapData.keySet()) {
            boolean found = false;
            for (String referencedKey : valueMap.values()) {
                if (configMapKey.equals(referencedKey)) {
                    found = true;
                    break;
                }
            }
            if (!found) {
                System.err.println("Error: configMap.data key '" + configMapKey + 
                                 "' is not referenced in values.env");
                System.exit(1);
            }
        }
        
        System.out.println("\nValidation passed: All keys match between configMap.data and values.env");
    }
    
    /**
     * Extrtype1 entrypoint from values YAML.
     */
    private static String extrtype1Entrypoint(Map<String, Object> values) {
        Object entrypoint = values.get("entrypoint");
        if (entrypoint instanceof List) {
            // Join list elements with space
            List<?> entryList = (List<?>) entrypoint;
            StringBuilder sb = new StringBuilder();
            for (Object item : entryList) {
                if (sb.length() > 0) sb.append(" ");
                sb.append(item.toString());
            }
            return sb.toString();
        } else if (entrypoint instanceof String) {
            return (String) entrypoint;
        }
        return null;
    }
    
    /**
     * Process command template with substitutions.
     */
    @SuppressWarnings("unchecked")
    private static String processCommandTemplate(String commandTemplate, 
                                               List<Map<String, Object>> valuesEnv,
                                               Map<String, String> configMapData) {
        String result = commandTemplate;
        
        for (Map<String, Object> envEntry : valuesEnv) {
            String envVarName = (String) envEntry.get("name");
            Map<String, Object> valueFrom = (Map<String, Object>) envEntry.get("valueFrom");
            
            if (envVarName != null && valueFrom != null) {
                Map<String, Object> configMapKeyRef = (Map<String, Object>) valueFrom.get("configMapKeyRef");
                if (configMapKeyRef != null) {
                    String configMapKey = (String) configMapKeyRef.get("key");
                    if (configMapKey != null) {
                        String finalValue = configMapData.get(configMapKey);
                        if (finalValue != null) {
                            // Replace all occurrences of the env var name with the final value
                            result = result.replace(envVarName, finalValue);
                        }
                    }
                }
            }
        }
        
        return result;
    }
