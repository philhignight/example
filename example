/**
 * Service for reading and writing EXAMPLE_FRAMEWORK response data in JSONL format.
 */
public class ExampleFrameworkResponseFileService {
    
    private static final Logger LOGGER = LogManager.getLogger(ExampleFrameworkResponseFileService.class);
    
    private final ObjectMapper objectMapper;
    private final String outputDir;
    
    public ExampleFrameworkResponseFileService(String outputDir) {
        this.outputDir = outputDir;
        this.objectMapper = new ObjectMapper();
    }
    
    /**
     * Get the EXAMPLE_FRAMEWORK response file path for a given submission ID.
     */
    public String getExampleFrameworkResponseFilePath(String todoFile, String todoFilePrefix) {
        return outputDir + "/todoapp-" + todoFilePrefix + todoFile + "-exampleframework-responses.jsonl";
    }
    
    /**
     * Write a EXAMPLE_FRAMEWORK response to the JSONL file.
     */
    public void writeExampleFrameworkResponse(ExampleFrameworkResponseData response, String todoFile, String todoFilePrefix) 
            throws IOException {
        String filePath = getExampleFrameworkResponseFilePath(todoFile, todoFilePrefix);
        
        // Ensure output directory exists
        File outputDirFile = new File(outputDir);
        if (!outputDirFile.exists()) {
            if (!outputDirFile.mkdirs()) {
                throw new IOException("Failed to create output directory: " + outputDir);
            }
            LOGGER.info("Created output directory: {}", outputDir);
        }
        
        // Append to file (create if doesn't exist)
        try (BufferedWriter writer = new BufferedWriter(new FileWriter(filePath, true))) {
            String json = objectMapper.writeValueAsString(response);
            writer.write(json);
            writer.newLine();
            
            if (response.getLineNumber() % 50 == 0) {
                LOGGER.info("Written {} EXAMPLE_FRAMEWORK responses to intermediate file", response.getLineNumber());
            } else {
                LOGGER.debug("Wrote EXAMPLE_FRAMEWORK response for line {} to {}", response.getLineNumber(), filePath);
            }
        } catch (IOException e) {
            LOGGER.error("Failed to write EXAMPLE_FRAMEWORK response for line {} to {}", 
                response.getLineNumber(), filePath, e);
            throw e;
        }
    }
    
    /**
     * Read all EXAMPLE_FRAMEWORK responses from the JSONL file.
     */
    public List<ExampleFrameworkResponseData> readAllExampleFrameworkResponses(String todoFile, String todoFilePrefix) 
            throws IOException {
        String filePath = getExampleFrameworkResponseFilePath(todoFile, todoFilePrefix);
        File file = new File(filePath);
        
        if (!file.exists()) {
            LOGGER.error("EXAMPLE_FRAMEWORK response file not found: {}. This can happen if: " +
                "1) The EXAMPLE_FRAMEWORK phase was skipped or failed, " +
                "2) The file was already processed and deleted in a previous run, " +
                "3) Recovery is attempting to resume BATCHREPORTING processing but the intermediate file is missing", 
                filePath);
            throw new FileNotFoundException("EXAMPLE_FRAMEWORK response file not found: " + filePath + 
                ". The file may have been deleted after successful processing or was never created.");
        }
        
        LOGGER.debug("Reading EXAMPLE_FRAMEWORK responses from: {} (size: {} bytes)", 
            filePath, file.length());
        
        List<ExampleFrameworkResponseData> responses = new ArrayList<>();
        int parseErrors = 0;
        
        try (BufferedReader reader = new BufferedReader(new FileReader(file))) {
            String line;
            int lineNum = 0;
            while ((line = reader.readLine()) != null) {
                lineNum++;
                if (line.trim().isEmpty()) {
                    LOGGER.debug("Skipping empty line {}", lineNum);
                    continue;
                }
                
                try {
                    ExampleFrameworkResponseData response = objectMapper.readValue(line, ExampleFrameworkResponseData.class);
                    responses.add(response);
                    
                    if (lineNum % 100 == 0) {
                        LOGGER.debug("Read {} EXAMPLE_FRAMEWORK responses", lineNum);
                    }
                } catch (Exception e) {
                    parseErrors++;
                    LOGGER.error("Failed to parse EXAMPLE_FRAMEWORK response at line {} in {}", lineNum, filePath, e);
                    // Continue reading other lines
                }
            }
        }
        
        if (parseErrors > 0) {
            LOGGER.warn("Read {} EXAMPLE_FRAMEWORK responses from {} with {} parse errors", 
                responses.size(), filePath, parseErrors);
        } else {
            LOGGER.info("Successfully read {} EXAMPLE_FRAMEWORK responses from {}", responses.size(), filePath);
        }
        
        return responses;
    }
    
    /**
     * Read EXAMPLE_FRAMEWORK responses starting from a specific line number (for recovery).
     */
    public List<ExampleFrameworkResponseData> readExampleFrameworkResponsesFromLine(String todoFile, String todoFilePrefix, 
                                                         int startFromLine) throws IOException {
        LOGGER.debug("Reading EXAMPLE_FRAMEWORK responses starting from line {}", startFromLine);
        
        List<ExampleFrameworkResponseData> allResponses = readAllExampleFrameworkResponses(todoFile, todoFilePrefix);
        List<ExampleFrameworkResponseData> filteredResponses = new ArrayList<>();
        
        int skipped = 0;
        for (ExampleFrameworkResponseData response : allResponses) {
            if (response.getLineNumber() > startFromLine) {
                filteredResponses.add(response);
            } else {
                skipped++;
            }
        }
        
        LOGGER.info("Read {} EXAMPLE_FRAMEWORK responses starting from line {} (skipped {} already processed)", 
            filteredResponses.size(), startFromLine, skipped);
        return filteredResponses;
    }
    
    /**
     * Delete the EXAMPLE_FRAMEWORK response file.
     */
    public void deleteExampleFrameworkResponseFile(String todoFile, String todoFilePrefix) throws IOException {
        String filePath = getExampleFrameworkResponseFilePath(todoFile, todoFilePrefix);
        File file = new File(filePath);
        
        if (file.exists()) {
            long fileSize = file.length();
            LOGGER.debug("Deleting EXAMPLE_FRAMEWORK response file: {} (size: {} bytes)", filePath, fileSize);
            
