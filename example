package com.example.todoapp.processor;

/**
 * Enum representing the processing states in order.
 * The ordinal values are used to determine if a state should be skipped.
 */
public enum ProcessingState {
    /**
     * Initial state - no processing started
     */
    NOT_STARTED,
    
    /**
     * Input file has been downloaded from SFTP
     */
    FILE_DOWNLOADED,
    
    /**
     * Todo File has been generated
     */
    TODO_FILE_GENERATED,
    
    /**
     * Input file has been archived on remote
     */
    INPUT_FILE_ARCHIVED,
    
    /**
     * Currently processing records through EXAMPLE_FRAMEWORK (partial completion)
     */
    EXAMPLE_FRAMEWORK_PROCESSING,
    
    /**
     * All records have been processed through EXAMPLE_FRAMEWORK
     */
    EXAMPLE_FRAMEWORK_COMPLETED,
    
    /**
     * BATCHREPORTING processing has been initialized
     */
    BATCHREPORTING_INITIALIZED,
    
    /**
     * Currently processing records through BATCHREPORTING
     */
    BATCHREPORTING_PROCESSING,
    
    /**
     * All records have been processed through BATCHREPORTING
     */
    BATCHREPORTING_COMPLETED,
    
    /**
     * COM and ERR files have been generated locally
     */
    OUTPUT_FILES_GENERATED,
    
    /**
     * Output files have been transferred to remote
     */
    OUTPUT_FILES_TRANSFERRED,
    
    /**
     * Local input file has been deleted
     */
    INPUT_FILE_DELETED,
    
    /**
     * BATCHREPORTING processing has been finalized
     */
    BATCHREPORTING_FINALIZED,
    
    /**
     * BATCHREPORTING output files have been transferred
     */
    BATCHREPORTING_FILES_TRANSFERRED,
    
    /**
     * Processing completed successfully
     */
    COMPLETED;
    
    /**
     * Check if this state is after the given state in the processing flow.
     */
    public boolean isAfter(ProcessingState other) {
        return this.ordinal() > other.ordinal();
    }
    
    /**
     * Check if this state is before the given state in the processing flow.
     */
    public boolean isBefore(ProcessingState other) {
        return this.ordinal() < other.ordinal();
    }
    
    /**
     * Check if this state is at or after the given state.
     */
    public boolean isAtOrAfter(ProcessingState other) {
        return this.ordinal() >= other.ordinal();
    }
