package com.example.todoapp.provider;

import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class ThreadProviderTest {
    
    @Test
    void testGetCurrentThread() {
        ThreadProvider provider = new ThreadProvider();
        
        Thread currentThread = Thread.currentThread();
        Thread result = provider.currentThread();
        
        assertEquals(currentThread, result);
        assertEquals(currentThread.getId(), result.getId());
        assertEquals(currentThread.getName(), result.getName());
    }
    
    @Test
    void testSleep() throws InterruptedException {
        ThreadProvider provider = new ThreadProvider();
        
        long startTime = System.currentTimeMillis();
        provider.sleep(100); // Sleep for 100ms
        long endTime = System.currentTimeMillis();
        
        long duration = endTime - startTime;
        // Should have slept for at least 100ms
        assertTrue(duration >= 100);
        // But not more than 200ms (allowing some margin)
        assertTrue(duration < 200);
    }
    
    @Test
    void testSleepInterrupted() {
        ThreadProvider provider = new ThreadProvider();
        Thread testThread = Thread.currentThread();
        
        // Set interrupt flag
        testThread.interrupt();
        
        // Sleep should throw InterruptedException
        assertThrows(InterruptedException.class, () -> provider.sleep(1000));
        
        // Clear interrupt flag
        Thread.interrupted();
    }
    
    @Test
    void testMultipleCalls() {
        ThreadProvider provider = new ThreadProvider();
        
        // Multiple calls should return the same thread when called from same thread
        Thread thread1 = provider.currentThread();
        Thread thread2 = provider.currentThread();
        Thread thread3 = provider.currentThread();
        
        assertEquals(thread1, thread2);
        assertEquals(thread2, thread3);
    }
