    /**
     * Create an error record for the ERR file.
     * Format: originalLine + statusCode + errorCode
     */
    public String createErrorRecord(String originalLine, String statusCode, String errorCode) {
        return originalLine + statusCode + errorCode;
    }
    
    /**
     * Create error records from validation errors.
     */
    public List<String> formatValidationErrors(List<ExampleFrameworkPhaseProcessor.ValidationError> validationErrors) {
        List<String> errorRecords = new ArrayList<>();
        
        for (ExampleFrameworkPhaseProcessor.ValidationError error : validationErrors) {
            RecordValidator.ValidationResult result = error.getValidationResult();
            String errorRecord = createErrorRecord(
                error.getRecord().getOriginalLine(),
                result.getPrcId(),  // statusCode (should be "36" for validation errors)
                result.getAltPrcId()  // errorCode (e.g., "506" for missing last name)
            );
            errorRecords.add(errorRecord);
        }
        
        return errorRecords;
    }
    
    /**
     * Create error records from EXAMPLE_FRAMEWORK errors.
     */
    public List<String> formatExampleFrameworkErrors(List<ExampleFrameworkPhaseProcessor.ExampleFrameworkError> exampleframeworkErrors) {
        List<String> errorRecords = new ArrayList<>();
        
        for (ExampleFrameworkPhaseProcessor.ExampleFrameworkError error : exampleframeworkErrors) {
            ExampleFrameworkResponseData responseData = error.getResponseData();
            String errorRecord = createErrorRecord(
                error.getRecord().getOriginalLine(),
                responseData.getReturnStatusCode(),
                responseData.getReturnReasonCode()
            );
            errorRecords.add(errorRecord);
        }
        
        return errorRecords;
    }
    
    /**
     * Create error records from EXAMPLE_FRAMEWORK response data (for BATCHREPORTING phase).
     */
    public List<String> formatExampleFrameworkResponseErrors(List<ExampleFrameworkResponseData> responses) {
        List<String> errorRecords = new ArrayList<>();
        
        for (ExampleFrameworkResponseData response : responses) {
            if (!"0".equals(response.getReturnStatusCode())) {
                String errorRecord = createErrorRecord(
                    response.getOriginalLine(),
                    response.getReturnStatusCode(),
                    response.getReturnReasonCode()
                );
                errorRecords.add(errorRecord);
            }
        }
        
        return errorRecords;
    }
    
    /**
     * Format error code for COM report display.
     */
    public String formatComReportErrorCode(String returnStatusCode, String returnReasonCode) {
        if ("0".equals(returnStatusCode)) {
            return null; // No error
        }
        
        String formattedReasonCode = Utils.leftPad("0", 5, returnReasonCode);
        
        // Determine prefix based on return status code
        String prefix;
        if ("2".equals(returnStatusCode)) {
            prefix = Constants.SUCCESS_REPORT_STATUS_CODE_PREFIX; // "04"
        } else {
            prefix = returnStatusCode;
        }
        
        return prefix + "/" + formattedReasonCode;
    }
    
    /**
     * Create a COM record entry.
     */
    public String createComRecord(TodoUpdateRecord record, String statusCode, String errorCode) {
        // COM file format would be defined here
        // For now, returning a simple format
        return String.format("%s|%s|%s", 
            record.getOriginalLine(), 
            statusCode, 
            errorCode);
    }
