    //     this.transtype1ionsProcessed = processed;
    //     this.transtype1ionsSkipped = skipped;
    //     this.transtype1ionsRejected = rejected;
    //     this.transtype1ionsAccepted = accepted;
    //     this.totalTxnProcessingTime = txnProcessingTime;
    // }
    
    public void addError(String statusCode, String description) {
        errorCounts.put(statusCode, errorCounts.getOrDefault(statusCode, 0) + 1);
        errorDescriptions.put(statusCode, description);
        transtype1ionsRejected += 1;
    }
    
    public void addNonCriticalError(String statusCode, String description) {
        nonCriticalCounts.put(statusCode, nonCriticalCounts.getOrDefault(statusCode, 0) + 1);
        nonCriticalDescriptions.put(statusCode, description);
        transtype1ionsRejected += 1;
    }
    
    @Override
    public String toString() {
        StringBuilder report = new StringBuilder();
        report.append("----------------------------------------------------------------------------------------------------\n");
        
        // Job properties section
        report.append(String.format("Job Name:         %s\n", jobName));
        report.append(String.format("Instance:         %s\n", instance));
        report.append(String.format("Run Date:         %s\n", startTime.format(DATE_FORMATTER)));
        report.append(String.format("Batch ID:         %s\n", batchId));
        report.append(String.format("Run ID:           %s\n", runId));
        report.append(String.format("Site ID:          %s\n", siteId));
        report.append(String.format("File Name:        %s\n", fileName));
        report.append(String.format("Restart Info:     %s\n", restartInfo));
        
        // Job status and timing
        report.append("Run Status:    COMPLETED\n");
        report.append(String.format("Job Began: %s\n", startTime.format(DATE_FORMATTER)));
        
        // Set job end time to now if not provided
        if (jobEndTime == null) {
            jobEndTime = LocalDateTime.now();
        }
        report.append(String.format("Job Ended: %s\n", jobEndTime.format(DATE_FORMATTER)));
        
        // Calculate processing time
        long processingTimeMs = Duration.between(startTime, jobEndTime).toMillis();
        report.append(String.format("Total Job Processing Time: %s ms\n", 
                NumberFormat.getNumberInstance(Locale.US).format(processingTimeMs)));
        report.append(String.format("Total Txn Processing Time: %s ms\n",
                NumberFormat.getNumberInstance(Locale.US).format(totalTxnProcessingTime)));
        
        int avgTime = transtype1ionsProcessed > 0 ? 
                (int) (totalTxnProcessingTime / transtype1ionsProcessed) : 0;
        report.append(String.format("Average Txn Processing Time: %d ms\n", avgTime));
        
        // Results section
        report.append("RESULTS\n");
        report.append("----------------------------------\n");
        report.append("Input Transtype1ions:\n");
        report.append(String.format("Transtype1ions Skipped:   %d\n", transtype1ionsSkipped));
        report.append(String.format("Transtype1ions Processed: %d\n", transtype1ionsProcessed));
        report.append("----------------------------------\n");
        report.append(String.format("Transtype1ions Rejected:  %d\n", transtype1ionsRejected));
        report.append(String.format("Transtype1ions Accepted:  %d\n", transtype1ionsAccepted));
        report.append("----------------------------------\n");
        
        // Error section - only include if there are errors
        if (!errorCounts.isEmpty()) {
            report.append("RUN WAS NOT COMPLETED OR FAILED\n");
            
            // ERROR section
            report.append("ERROR\n");
            report.append("--------------------------------------------------------------------------------\n");
            report.append("   Count   Return Status/Return Code and Description\n");
            report.append("--------------------------------------------------------------------------------\n");
            
            // Sort the error codes for consistent output
            List<String> sortedErrorCodes = new ArrayList<>(errorCounts.keySet());
            sortedErrorCodes.sort(String::compareTo);
            
            for (String code : sortedErrorCodes) {
                report.append(String.format("%8d    %s %s\n",
                        errorCounts.get(code), code, errorDescriptions.get(code)));
            }
            report.append("--------------------------------------------------------------------------------\n");
        }
        
        // NON_CRITICAL section
        if (!nonCriticalCounts.isEmpty()) {
            report.append("NON_CRITICAL\n");
            report.append("--------------------------------------------------------------------------------\n");
            report.append("   Count   Return Status/Return Code and Description\n");
            report.append("--------------------------------------------------------------------------------\n");
            
            List<String> sortedNonCriticalCodes = new ArrayList<>(nonCriticalCounts.keySet());
            sortedNonCriticalCodes.sort(String::compareTo);
            
            for (String code : sortedNonCriticalCodes) {
                report.append(String.format("%8d    %s %s\n",
                        nonCriticalCounts.get(code), code, nonCriticalDescriptions.get(code)));
            }
            report.append("--------------------------------------------------------------------------------\n");
        }
        
        report.append("----------------------------------------------------------------------------------------------------\n");
        return report.toString();
    }
