            if (currentOldIdKey.equals(processedOldIdKey) && !currentNewIdKey.equals(processedNewIdKey)) {
                return new ValidationResult(false, Constants.BatchReportingCounters.TODO_RECORD_PRC_ID,
                        Constants.BatchReportingCounters.Transtype1ionSupercededByALaterOne.ALT_PRC_ID,
                    Constants.BatchReportingCounters.TODO_RECORD_PRC_ID,
                        Constants.BatchReportingCounters.Transtype1ionSupercededByALaterOne.PRC_CNTR_TYPE1N_CD,
                        Constants.BatchReportingCounters.Transtype1ionSupercededByALaterOne.PRC_CNTR_LBL_TX);
            }

            // Check for transtype1ion reversal (BR.7) - A to B, then B to A
            if (currentOldIdKey.equals(processedNewIdKey) && currentNewIdKey.equals(processedOldIdKey)) {
                return new ValidationResult(false, Constants.BatchReportingCounters.TODO_RECORD_PRC_ID,
                        Constants.BatchReportingCounters.Transtype1ionReversedByALaterOne.ALT_PRC_ID,
                    Constants.BatchReportingCounters.TODO_RECORD_PRC_ID,
                        Constants.BatchReportingCounters.Transtype1ionReversedByALaterOne.PRC_CNTR_TYPE1N_CD,
                        Constants.BatchReportingCounters.Transtype1ionReversedByALaterOne.PRC_CNTR_LBL_TX);
