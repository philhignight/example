            successReport.addError(errorCode, errorMessage);
        } else {
            successReport.addNonCriticalError(errorCode, errorMessage);
        }
    }
    
    /**
     * Determine if an error is transient based on return code.
     */
    public boolean isTransientError(String returnCode) {
        // Define logic for determining transient errors
        // This could be configurable or based on specific codes
        return "3".equals(returnCode) || "4".equals(returnCode);
    }
    
    /**
     * Format error message for display/logging.
     */
    public String formatErrorMessage(String errorMessage) {
        if (errorMessage == null) {
            return "";
        }
        
        // Remove newlines and clean up
        return errorMessage.replaceAll("[\r\n]+", " ").trim();
    }
    
    /**
     * Log error with appropriate level based on severity.
     */
    public void logError(String context, String returnCode, String statusCode, 
                        String errorMessage, Exception exception) {
        
        String formattedMessage = String.format(
            "%s - Return code: %s, Status code: %s, Message: %s",
            context, returnCode, statusCode, formatErrorMessage(errorMessage)
        );
        
        if ("0".equals(returnCode)) {
            // Success - no logging needed
            return;
        } else if (isTransientError(returnCode)) {
            LOGGER.warn(formattedMessage, exception);
        } else {
            LOGGER.error(formattedMessage, exception);
        }
    }
    
    /**
     * Determine if processing should continue after an error.
     */
    public boolean shouldContinueAfterError(String returnCode) {
        // Critical errors that should stop processing
        return !"9".equals(returnCode); // Example: system failure
    }
