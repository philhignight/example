        }
        if (!outputDir.isDirectory()) {
            throw new IllegalArgumentException(
                    "outputDir (" + outputDirStr + ") must be a directory");
        }

        // Validate stop file path
        if (Utils.isEmpty(config.getStopFilePath())) {
